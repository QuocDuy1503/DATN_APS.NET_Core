@using DATN_TMS.Models
@using Microsoft.AspNetCore.Http
@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<ThongBao>
@{
    var role = Context.Session.GetString("Role");
    Layout = role switch
    {
        "SINH_VIEN" => "~/Views/Shared/_Layout_SV.cshtml",
        "GIANG_VIEN" => "~/Views/Shared/_Layout_GV.cshtml",
        "BO_MON" => "~/Views/Shared/_LayoutGVBoMon.cshtml",
        _ => "~/Views/Shared/_LayoutBCNKhoa.cshtml"
    };
    ViewData["Title"] = "Thông báo";
    var filter = (ViewBag.Filter as string ?? "all").ToLower();
    var hasData = Model != null && Model.Any();
}

<style>
    .content-body.thongbao-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .thongbao-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); display: flex; flex-direction: column;
        min-height: calc(100vh - 140px); font-family: inherit;
    }

    .page-header-row { margin-bottom: 15px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }
    .page-subtitle { color: #666; font-size: 13px; margin-top: 4px; }

    .toolbar-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; gap: 15px; flex-wrap: wrap; }
    .filter-wrapper { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .filter-btn { padding: 8px 16px; border-radius: 6px; border: 1px solid #d1d5db; background: #fff; color: #374151; text-decoration: none; font-weight: 600; font-size: 13px; transition: all 0.15s; }
    .filter-btn:hover { border-color: #484BE0; color: #484BE0; }
    .filter-btn.active { background: #484BE0; color: #fff; border-color: #484BE0; }

    .btn-mark-all { padding: 8px 16px; border-radius: 6px; border: 1px solid #484BE0; background: #eef2ff; color: #484BE0; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.15s; }
    .btn-mark-all:hover { background: #484BE0; color: #fff; }

    /* Table styles */
    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    .table-scroll { flex: 1; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; table-layout: fixed; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px !important; color: #444; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; font-size: 13px !important; color: #333; }
    tbody tr { cursor: default; transition: background 0.15s; }
    tbody tr:hover { background: #f8f9ff; }
    tbody tr.unread { background: #faf8ff; }
    tbody tr.unread:hover { background: #f3f0ff; }

    .notif-icon-cell { width: 40px; text-align: center; }
    .notif-icon { width: 32px; height: 32px; border-radius: 50%; background: #eef2ff; display: inline-flex; align-items: center; justify-content: center; color: #484BE0; font-size: 14px; }
    tr.unread .notif-icon { background: #484BE0; color: #fff; }

    .notif-content-cell { }
    .notif-title { font-weight: 700; color: #333; margin-bottom: 4px; }
    tr.unread .notif-title { color: #1a1a2e; }
    .notif-desc { color: #555; font-size: 13px; line-height: 1.5; white-space: pre-wrap; word-wrap: break-word; }

    .notif-time-cell { width: 140px; text-align: center; color: #888; font-size: 12px; }
    .notif-status-cell { width: 120px; text-align: center; }

    .status-badge { padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: 600; display: inline-block; }
    .badge-read { background: #f3f4f6; color: #6b7280; }
    .badge-unread { background: #484BE0; color: #fff; }

    .notif-action-cell { width: 140px; text-align: center; }
    .btn-mark-read { padding: 6px 12px; border-radius: 6px; border: 1px solid #d0c4ff; background: #ede7ff; color: #5c2d91; font-weight: 600; cursor: pointer; font-size: 11px; transition: all 0.15s; }
    .btn-mark-read:hover { background: #484BE0; color: #fff; border-color: #484BE0; }

    /* Empty state */
    .table-msg-row td { text-align: center; padding: 60px 20px !important; }
    .table-msg-icon { font-size: 40px; margin-bottom: 12px; display: block; color: #484BE0; }
    .table-msg-title { font-size: 15px; font-weight: 700; color: #333; margin-bottom: 6px; }
    .table-msg-text { font-size: 13px; color: #6b7280; }

    /* Pagination */
    .pagination-container { display: flex; justify-content: center; margin-top: auto; padding-top: 16px; }
    .pagination { display: inline-flex; gap: 8px; padding: 0; margin: 0; list-style: none; }
    .pagination li a, .pagination li span { min-width: 38px; height: 36px; border-radius: 6px; border: 1px solid #d1d5db; background: #fff; color: #374151; display: inline-flex; align-items: center; justify-content: center; padding: 0 10px; text-decoration: none; font-weight: 600; transition: all 0.15s ease; font-size: 13px; }
    .pagination li a:hover { border-color: #484BE0; color: #484BE0; }
    .pagination li.active span { background: #484BE0; border-color: #484BE0; color: #fff; }
    .pagination li.disabled span, .pagination li.disabled a { color: #9ca3af; border-color: #e5e7eb; cursor: default; }
</style>

<div class="content-body thongbao-page">
    <div class="content-card">
        <div class="page-header-row">
            <h2 class="page-title">Thông báo</h2>
        </div>

        <div class="toolbar-row">
            <div class="filter-wrapper">
                <a asp-area="" asp-controller="ThongBao" asp-action="Index" asp-route-filter="all" class="filter-btn @(filter == "all" ? "active" : "")">
                    <i class="fa-solid fa-list"></i> Tất cả
                </a>
                <a asp-area="" asp-controller="ThongBao" asp-action="Index" asp-route-filter="unread" class="filter-btn @(filter == "unread" ? "active" : "")">
                    <i class="fa-regular fa-envelope"></i> Chưa đọc
                </a>
                <a asp-area="" asp-controller="ThongBao" asp-action="Index" asp-route-filter="read" class="filter-btn @(filter == "read" ? "active" : "")">
                    <i class="fa-regular fa-envelope-open"></i> Đã đọc
                </a>
            </div>
            <button type="button" class="btn-mark-all" id="btnMarkAllRead">
                <i class="fa-solid fa-check-double"></i> Đánh dấu tất cả đã đọc
            </button>
        </div>

        <div class="table-responsive">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th class="notif-icon-cell"></th>
                            <th>Nội dung thông báo</th>
                            <th class="notif-time-cell">Thời gian</th>
                            <th class="notif-status-cell">Trạng thái</th>
                            <th class="notif-action-cell">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (hasData)
                        {
                            foreach (var item in Model)
                            {
                                var isRead = item.TrangThaiXem == true;
                                <tr class="@(isRead ? "read" : "unread")" data-id="@item.Id">
                                    <td class="notif-icon-cell">
                                        <span class="notif-icon">
                                            <i class="fa-regular fa-bell"></i>
                                        </span>
                                    </td>
                                    <td class="notif-content-cell">
                                        <div class="notif-title" title="@item.TieuDe">@item.TieuDe</div>
                                        <div class="notif-desc">@item.NoiDung</div>
                                    </td>
                                    <td class="notif-time-cell">
                                        <i class="fa-regular fa-clock"></i>
                                        @(item.NgayTao?.ToString("HH:mm dd/MM/yyyy") ?? "---")
                                    </td>
                                    <td class="notif-status-cell">
                                        @if (isRead)
                                        {
                                            <span class="status-badge badge-read">Đã đọc</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge badge-unread">Chưa đọc</span>
                                        }
                                    </td>
                                    <td class="notif-action-cell">
                                        @if (!isRead)
                                        {
                                            <button type="button" class="btn-mark-read" data-id="@item.Id" onclick="event.stopPropagation();">
                                                <i class="fa-solid fa-check"></i> Đánh dấu đã đọc
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr class="table-msg-row">
                                <td colspan="5">
                                    <span class="table-msg-icon"><i class="fa-regular fa-bell-slash"></i></span>
                                    <div class="table-msg-title">Không có thông báo</div>
                                    <div class="table-msg-text">Chưa có thông báo nào trong danh sách này.</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (hasData && Model.PageCount > 1)
        {
            <div class="pagination-container">
                @Html.PagedListPager(Model, page => Url.Action("Index", "ThongBao", new { area = "", page, filter }),
                    new PagedListRenderOptions
                    {
                        LiElementClasses = new string[] { "page-item" },
                        PageClasses = new string[] { "page-link" },
                        DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                        DisplayLinkToNextPage = PagedListDisplayMode.Always,
                        LinkToPreviousPageFormat = "«",
                        LinkToNextPageFormat = "»",
                        MaximumPageNumbersToDisplay = 5
                    })
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Click vào row để đánh dấu đã đọc (không chuyển trang)
        const rows = document.querySelectorAll('tbody tr[data-id]');
        rows.forEach(row => {
            row.addEventListener('click', async () => {
                const id = row.dataset.id;
                if (row.classList.contains('unread')) {
                    await markAsRead(id);
                    row.classList.remove('unread');
                    row.classList.add('read');
                    const badge = row.querySelector('.status-badge');
                    if (badge) {
                        badge.classList.remove('badge-unread');
                        badge.classList.add('badge-read');
                        badge.textContent = 'Đã đọc';
                    }
                    const actionCell = row.querySelector('.notif-action-cell');
                    if (actionCell) actionCell.innerHTML = '';
                }
            });
        });

        // Đánh dấu đã đọc từng thông báo
        const markButtons = document.querySelectorAll('.btn-mark-read');
        markButtons.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation();
                const id = btn.dataset.id;
                await markAsRead(id);
                window.location.reload();
            });
        });

        // Đánh dấu tất cả đã đọc
        const btnMarkAll = document.getElementById('btnMarkAllRead');
        if (btnMarkAll) {
            btnMarkAll.addEventListener('click', async () => {
                await fetch('/ThongBao/MarkAllAsRead', { method: 'POST' });
                window.location.reload();
            });
        }
    });

    async function markAsRead(id) {
        try {
            await fetch('/ThongBao/MarkAsRead', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: parseInt(id) })
            });
        } catch (e) {
            console.error(e);
        }
    }
</script>
