@using DATN_TMS.Models
@using Microsoft.AspNetCore.Http
@model ThongBao
@{
    var role = Context.Session.GetString("Role");
    Layout = role switch
    {
        "SINH_VIEN" => "~/Views/Shared/_Layout_SV.cshtml",
        "GIANG_VIEN" => "~/Views/Shared/_Layout_GV.cshtml",
        "BO_MON" => "~/Views/Shared/_LayoutGVBoMon.cshtml",
        _ => "~/Views/Shared/_LayoutBCNKhoa.cshtml"
    };
    ViewData["Title"] = "Chi tiết thông báo";
}

<style>
    .notif-detail-card {
        background: #fff;
        border-radius: 8px;
        padding: 24px;
        border: 1px solid #eee;
        max-width: 800px;
    }
    .notif-detail-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        padding-bottom: 14px;
        border-bottom: 1px solid #f0f0f0;
    }
    .notif-detail-header a {
        color: #6a1b9a;
        font-weight: 600;
        text-decoration: none;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .notif-detail-header a:hover { text-decoration: underline; }
    .notif-detail-title {
        font-size: 18px;
        font-weight: 800;
        color: #333;
        margin-bottom: 8px;
    }
    .notif-detail-meta {
        font-size: 13px;
        color: #888;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 18px;
    }
    .notif-detail-body {
        font-size: 14px;
        color: #444;
        line-height: 1.7;
        white-space: pre-line;
        padding: 16px;
        background: #faf9ff;
        border-radius: 6px;
        border: 1px solid #f0eeff;
        min-height: 80px;
    }
    .notif-detail-link {
        margin-top: 16px;
        padding-top: 14px;
        border-top: 1px solid #f0f0f0;
    }
    .notif-detail-link a {
        color: #6a1b9a;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
    }
    .notif-detail-link a:hover { text-decoration: underline; }
</style>

<div class="content-body">
    <div class="notif-detail-card">
        <div class="notif-detail-header">
            <a asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách</a>
        </div>

        <div class="notif-detail-title">@Model.TieuDe</div>

        <div class="notif-detail-meta">
            <i class="fa-regular fa-clock"></i>
            <span>@(Model.NgayTao?.ToString("dd/MM/yyyy HH:mm") ?? "Không rõ thời gian")</span>
            @if (Model.TrangThaiXem == true)
            {
                <span style="margin-left: 8px; background: #eef2ff; color: #4b5563; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600;">Đã đọc</span>
            }
        </div>

        <div class="notif-detail-body">@(Model.NoiDung ?? "Không có nội dung.")</div>

        @if (!string.IsNullOrWhiteSpace(Model.LinkLienKet))
        {
            <div class="notif-detail-link">
                <a href="@Model.LinkLienKet">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> Mở liên kết đính kèm
                </a>
            </div>
        }
    </div>
</div>
