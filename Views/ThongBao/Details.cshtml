@using DATN_TMS.Models
@using Microsoft.AspNetCore.Http
@model ThongBao
@{
    var role = Context.Session.GetString("Role");
    Layout = role switch
    {
        "SINH_VIEN" => "~/Views/Shared/_Layout_SV.cshtml",
        "GIANG_VIEN" => "~/Views/Shared/_Layout_GV.cshtml",
        "BO_MON" => "~/Views/Shared/_LayoutGVBoMon.cshtml",
        _ => "~/Views/Shared/_LayoutBCNKhoa.cshtml"
    };
    ViewData["Title"] = "Chi tiết thông báo";
}

<style>
    .content-body.thongbao-detail-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .thongbao-detail-page .content-card {
        background: #fff; border-radius: 8px; padding: 24px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); max-width: 800px;
    }

    .back-link { display: inline-flex; align-items: center; gap: 8px; color: #484BE0; font-weight: 600; text-decoration: none; font-size: 13px; margin-bottom: 20px; padding: 8px 0; }
    .back-link:hover { text-decoration: underline; }
    .back-link i { font-size: 12px; }

    .notif-header { border-bottom: 1px solid #e5e7eb; padding-bottom: 16px; margin-bottom: 20px; }
    .notif-title { font-size: 20px; font-weight: 700; color: #1a1a2e; margin: 0 0 12px 0; line-height: 1.4; }
    .notif-meta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
    .notif-meta-item { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: #666; }
    .notif-meta-item i { color: #484BE0; }

    .status-badge { padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: 600; display: inline-block; }
    .badge-read { background: #f3f4f6; color: #6b7280; }
    .badge-unread { background: #484BE0; color: #fff; }

    .notif-body { background: #f8f9ff; border: 1px solid #e8ebff; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
    .notif-body-content { font-size: 14px; color: #333; line-height: 1.8; white-space: pre-line; }

    .notif-link-section { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; }
    .notif-link-title { font-size: 13px; font-weight: 600; color: #666; margin-bottom: 10px; }
    .notif-link-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background: #484BE0; color: #fff; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 13px; transition: all 0.15s; }
    .notif-link-btn:hover { background: #3538b2; }
    .notif-link-btn i { font-size: 12px; }
</style>

<div class="content-body thongbao-detail-page">
    <div class="content-card">
        <a asp-area="" asp-controller="ThongBao" asp-action="Index" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách thông báo
        </a>

        <div class="notif-header">
            <h1 class="notif-title">@Model.TieuDe</h1>
            <div class="notif-meta">
                <span class="notif-meta-item">
                    <i class="fa-regular fa-clock"></i>
                    @(Model.NgayTao?.ToString("HH:mm - dd/MM/yyyy") ?? "Không rõ thời gian")
                </span>
                @if (Model.TrangThaiXem == true)
                {
                    <span class="status-badge badge-read">Đã đọc</span>
                }
                else
                {
                    <span class="status-badge badge-unread">Chưa đọc</span>
                }
            </div>
        </div>

        <div class="notif-body">
            <div class="notif-body-content">@(Model.NoiDung ?? "Không có nội dung.")</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.LinkLienKet))
        {
            <div class="notif-link-section">
                <div class="notif-link-title">
                    <i class="fa-solid fa-link"></i> Liên kết đính kèm
                </div>
                <a href="@Model.LinkLienKet" class="notif-link-btn">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> Mở liên kết
                </a>
            </div>
        }
    </div>
</div>
