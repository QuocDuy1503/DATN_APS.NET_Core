@model DATN_TMS.Areas.GiangVien.Models.ChiTietHoiDongChamDiemViewModel

<style>
    .content-body.chamdiem-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .chamdiem-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); min-height: calc(100vh - 140px);
    }
    .page-header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; }
    .page-meta { font-size: 13px; color: #6c757d; margin-top: 6px; display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
    .page-meta i { margin-right: 4px; }

    .btn-back { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; padding: 8px 14px; border-radius: 6px; font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 12px; }
    .btn-back:hover { background: #e5e7eb; color: #1f2937; }

    .info-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 20px; }
    .info-card-header { background: #f8f9fa; padding: 12px 16px; border-bottom: 1px solid #e5e7eb; font-weight: 600; font-size: 14px; color: #374151; display: flex; align-items: center; gap: 8px; }
    .info-card-body { padding: 16px; }

    .member-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
    .member-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; border: 1px solid #e5e7eb; border-radius: 6px; background: #fff; }
    .member-item.done { background: #ecfdf5; border-color: #86efac; }
    .member-name { font-weight: 600; font-size: 13px; color: #1f2937; }
    .member-role { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .member-status { font-size: 16px; }
    .member-status .done { color: #16a34a; }
    .member-status .pending { color: #9ca3af; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; }
    .table-scroll { max-height: calc(100vh - 400px); overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; color: #444; white-space: nowrap; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; color: #333; }
    tbody tr:hover { background: #f9f9f9; }
    tbody tr.row-success { background: #ecfdf5; }

    .status-badge { padding: 5px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; color: #fff; white-space: nowrap; display: inline-flex; align-items: center; gap: 4px; }
    .status-cuoiky { background: #0d6efd; }
    .status-giuaky { background: #17a2b8; }
    .status-done { background: #16a34a; }
    .status-pending { background: #f59e0b; }
    .status-info { background: #17a2b8; }
    .status-primary { background: #0d6efd; }
    .status-warning { background: #f59e0b; color: #000; }

    .btn-action { padding: 6px 12px; border-radius: 4px; font-size: 12px; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; border: none; cursor: pointer; margin-right: 4px; }
    .btn-primary { background: #0d6efd; color: #fff; }
    .btn-primary:hover { background: #0b5ed7; color: #fff; }
    .btn-outline { background: #fff; color: #6c757d; border: 1px solid #d1d5db; }
    .btn-outline:hover { background: #f3f4f6; }

    .empty-state { text-align: center; padding: 40px 20px; color: #6c757d; }
    .empty-state i { font-size: 40px; margin-bottom: 12px; color: #d1d5db; }

    .alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 13px; display: flex; align-items: center; justify-content: space-between; }
    .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
    .alert-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
    .alert .btn-close { background: none; border: none; font-size: 18px; cursor: pointer; color: inherit; opacity: 0.7; }
</style>

<div class="content-body chamdiem-page">
    <div class="content-card">
        <a href="@Url.Action("Index")" class="btn-back"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>

        <div class="page-header-row">
            <div>
                <h2 class="page-title">@Model.HoiDong.TenHoiDong</h2>
                <div class="page-meta">
                    <span class="status-badge @(Model.HoiDong.LoaiHoiDong == "CUOI_KY" ? "status-cuoiky" : "status-giuaky")">@Model.HoiDong.LoaiHoiDongDisplay</span>
                    <span>@Model.HoiDong.TenBoMon</span>
                    <span><i class="fa-solid fa-calendar"></i> @Model.HoiDong.NgayBaoCao?.ToString("dd/MM/yyyy")</span>
                    <span><i class="fa-solid fa-location-dot"></i> @Model.HoiDong.DiaDiem</span>
                </div>
            </div>
            <span class="status-badge status-primary" style="font-size: 14px;">Vai trò: @Model.HoiDong.VaiTroDisplay</span>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="btn-close" onclick="this.parentElement.remove();">&times;</button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <span>@TempData["ErrorMessage"]</span>
                <button type="button" class="btn-close" onclick="this.parentElement.remove();">&times;</button>
            </div>
        }

        <!-- Thành viên hội đồng -->
        <div class="info-card">
            <div class="info-card-header"><i class="fa-solid fa-users"></i> Thành viên hội đồng</div>
            <div class="info-card-body">
                <div class="member-grid">
                    @foreach (var tv in Model.ThanhViens.OrderBy(t => t.VaiTro == "CHU_TICH" ? 0 : t.VaiTro == "THU_KY" ? 1 : 2))
                    {
                        <div class="member-item @(tv.DaChamDiem ? "done" : "")">
                            <div>
                                <div class="member-name">@tv.TenGiangVien</div>
                                <div class="member-role">@tv.VaiTroDisplay</div>
                            </div>
                            <div class="member-status">
                                @if (tv.DaChamDiem)
                                {
                                    <i class="fa-solid fa-circle-check done"></i>
                                }
                                else
                                {
                                    <i class="fa-regular fa-circle pending"></i>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Danh sách đề tài -->
        <div class="info-card">
            <div class="info-card-header"><i class="fa-solid fa-file-lines"></i> Danh sách đề tài (@Model.PhienBaoVes.Count)</div>
            <div class="info-card-body" style="padding: 0;">
                @if (!Model.PhienBaoVes.Any())
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-folder-open"></i>
                        <h5>Chưa có đề tài nào</h5>
                        <p>Hội đồng chưa được phân đề tài để chấm điểm.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive" style="border: none; border-radius: 0;">
                        <div class="table-scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">STT</th>
                                        <th style="min-width: 150px;">Sinh viên</th>
                                        <th style="min-width: 200px;">Đề tài</th>
                                        <th style="width: 150px;">GVHD</th>
                                        <th style="width: 100px;">Điểm GVHD</th>
                                        <th style="width: 100px;">Điểm TB HĐ</th>
                                        <th style="width: 120px;">Trạng thái</th>
                                        <th style="width: 160px;">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pb in Model.PhienBaoVes)
                                    {
                                        var diemTBHD = pb.DiemHoiDong.Any() ? pb.DiemHoiDong.Average(d => d.DiemSo) : 0;
                                        <tr class="@(pb.DaXacNhan ? "row-success" : "")">
                                            <td><strong>@pb.SttBaoCao</strong></td>
                                            <td>
                                                <strong>@pb.TenSinhVien</strong><br />
                                                <small style="color: #6b7280;">@pb.Mssv</small>
                                            </td>
                                            <td>
                                                <strong>@pb.TenDeTai</strong><br />
                                                <small style="color: #6b7280;">@pb.MaDeTai</small>
                                            </td>
                                            <td>@pb.TenGVHD</td>
                                            <td>
                                                @if (pb.DiemGVHD.HasValue)
                                                {
                                                    <span class="status-badge status-info">@pb.DiemGVHD.Value.ToString("F1")</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-warning">Chưa chấm</span>
                                                }
                                            </td>
                                            <td>
                                                @if (pb.DiemHoiDong.Any())
                                                {
                                                    <span class="status-badge status-primary">@diemTBHD.ToString("F2")</span>
                                                }
                                                else
                                                {
                                                    <span style="color: #9ca3af;">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (pb.DaXacNhan)
                                                {
                                                    <span class="status-badge status-done"><i class="fa-solid fa-check"></i> Đã xác nhận</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-pending"><i class="fa-solid fa-clock"></i> Chờ xác nhận</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!pb.DaXacNhan)
                                                {
                                                    <a href="@Url.Action("ChamDiem", new { phienBaoVeId = pb.Id })" class="btn-action btn-primary">
                                                        <i class="fa-solid fa-pen"></i> Chấm điểm
                                                    </a>
                                                }
                                                <a href="@Url.Action("BangDiemTongHop", new { phienBaoVeId = pb.Id })" class="btn-action btn-outline">
                                                    <i class="fa-solid fa-table"></i> Tổng hợp
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
