@model DATN_TMS.Areas.GiangVien.Models.ChiTietHoiDongChamDiemViewModel

@{
    var laHoiDongGiuaKy = Model.HoiDong.LoaiHoiDong == "GIUA_KY";
}

<style>
    :root { --primary: #484BE0; }

    .content-body.chamdiem-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .chamdiem-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); display: flex; flex-direction: column;
        min-height: calc(100vh - 140px); font-family: inherit;
    }

    .page-header-row { margin-bottom: 15px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }

    .btn-back { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; padding: 8px 14px; border-radius: 6px; font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 12px; }
    .btn-back:hover { background: #e5e7eb; color: #1f2937; }

    .hd-info { background: #f0f4ff; border: 1px solid #dbeafe; border-radius: 8px; padding: 14px 18px; margin-bottom: 20px; font-size: 13px; color: #333; display: flex; flex-wrap: wrap; align-items: center; gap: 16px; }
    .hd-info i { color: #2563eb; }
    .hd-info strong { color: #1e3a5f; }
    .hd-info-item { display: flex; align-items: center; gap: 6px; }

    .toolbar-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; gap: 15px; flex-wrap: wrap; }
    .filter-item { display: flex; flex-direction: column; gap: 4px; }
    .filter-label { font-weight: 500 !important; font-size: 13px !important; color: #333; display: block; margin-bottom: 4px; }
    .toolbar-input { background: #fff !important; font-size: 13px !important; padding: 8px 12px !important; border: 1px solid #ced4da !important; border-radius: 4px !important; height: 36px !important; }
    .toolbar-input:focus { border-color: var(--primary) !important; box-shadow: 0 0 0 2px rgba(72, 75, 224, 0.1) !important; outline: none; }

    .hd-note { font-size: 12px; color: #6b7280; display: flex; align-items: center; gap: 6px; }
    .hd-note i { color: #f59e0b; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    .table-scroll { flex: 1; max-height: calc(100vh - 360px); overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px !important; color: #444; line-height: 1.4; white-space: nowrap; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; font-size: 13px !important; color: #333; }
    tbody tr:hover { background: #f9f9f9; }

    .td-ellipsis { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .toggle-btn { width: 30px; height: 30px; border-radius: 6px; border: 1px solid #e5e7eb; background: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: .15s ease; font-size: 13px; color: #111827; }
    .toggle-btn:hover { background: #f3f4f6; border-color: var(--primary); color: var(--primary); }

    .detail-row { background: #f9fafb; }
    .detail-row > td { padding: 16px !important; }

    .student-table { width: 100%; margin: 0; border: 1px solid #e5e7eb; border-radius: 8px; border-collapse: separate; border-spacing: 0; overflow: hidden; background: #fff; }
    .student-table thead th { background: #f8fafc; padding: 10px 12px; border-bottom: 1px solid #e5e7eb; white-space: nowrap; font-size: 12px !important; font-weight: 600; color: #374151; }
    .student-table tbody td { font-size: 12px !important; padding: 10px 12px; border-bottom: 1px solid #f1f5f9; color: #111827; }
    .student-table tbody tr:last-child td { border-bottom: none; }
    .student-table td[rowspan] { vertical-align: middle; text-align: center; }

    .status-badge { padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; display: inline-block; }
    .status-approved { background: #dcfce7; color: #166534; }
    .status-pending { background: #fef3c7; color: #92400e; }
    .status-cuoiky { background: #dbeafe; color: #1e40af; }
    .status-giuaky { background: #e0e7ff; color: #3730a3; }
    .status-notyet { background: #fee2e2; color: #991b1b; }

    .file-link { color: #2563eb; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; font-weight: 500; font-size: 12px; }
    .file-link:hover { text-decoration: underline; }

    .edit-icon { width: 34px; height: 34px; border-radius: 8px; border: 1px solid #e5e7eb; background: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: .15s ease; text-decoration: none; }
    .edit-icon i { font-size: 14px; color: #111827; }
    .edit-icon:hover { background: #f3f4f6; border-color: var(--primary); }
    .edit-icon:hover i { color: var(--primary); }
    .btn-bangdiem { background: #e7f1ff; border-color: #93c5fd; }
    .btn-bangdiem:hover { background: #dbeafe; }

    .plan-cell { vertical-align: middle; text-align: center; }
    .score-cell { font-weight: 600; color: #1e40af; font-size: 13px; }
    .no-score { color: #9ca3af; font-style: italic; font-weight: 400; }

    .empty-state { text-align: center; padding: 60px 20px; color: #6b7280; }
    .empty-state i { font-size: 48px; margin-bottom: 16px; color: #d1d5db; }
    .empty-state h4 { font-size: 16px; font-weight: 600; margin-bottom: 8px; color: #374151; }
    .empty-state p { font-size: 13px; }

    .alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 13px; display: flex; align-items: center; justify-content: space-between; }
    .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
    .alert-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
    .alert .btn-close { background: none; border: none; font-size: 18px; cursor: pointer; color: inherit; opacity: 0.7; }
    .alert .btn-close:hover { opacity: 1; }

    /* Member badges */
    .member-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
    .member-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 20px; font-size: 12px; }
    .member-badge.done { background: #ecfdf5; border-color: #86efac; }
    .member-badge .icon { font-size: 14px; }
    .member-badge .icon.done { color: #16a34a; }
    .member-badge .icon.pending { color: #9ca3af; }
    .member-badge .name { font-weight: 600; color: #374151; }
    .member-badge .role { color: #6b7280; }
</style>

<div class="content-body chamdiem-page">
    <div class="content-card">
        <a href="@Url.Action("Index")" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>

        <div class="page-header-row">
            <h2 class="page-title">Chấm điểm báo cáo</h2>
        </div>

        <div class="hd-info">
            <div class="hd-info-item">
                <i class="fa-solid fa-users"></i>
                <strong>@Model.HoiDong.TenHoiDong</strong>
            </div>
            <div class="hd-info-item">
                <span class="status-badge @(Model.HoiDong.LoaiHoiDong == "CUOI_KY" ? "status-cuoiky" : "status-giuaky")">
                    @(Model.HoiDong.LoaiHoiDong == "CUOI_KY" ? "Cuối kỳ" : "Giữa kì")
                </span>
            </div>
            <div class="hd-info-item">
                <i class="fa-solid fa-calendar"></i>
                @(Model.HoiDong.NgayBaoCao?.ToString("dd/MM/yyyy") ?? "-")
            </div>
            <div class="hd-info-item">
                <i class="fa-solid fa-location-dot"></i>
                @(Model.HoiDong.DiaDiem ?? "-")
            </div>
            <div class="hd-info-item" style="margin-left: auto;">
                <span style="font-weight: 600; color: #1e40af;">Vai trò: @Model.HoiDong.VaiTroDisplay</span>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="btn-close" onclick="this.parentElement.remove();">&times;</button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <span>@TempData["ErrorMessage"]</span>
                <button type="button" class="btn-close" onclick="this.parentElement.remove();">&times;</button>
            </div>
        }

        <!-- Thành viên hội đồng -->
        <div class="member-badges">
            @foreach (var tv in Model.ThanhViens.OrderBy(t => t.VaiTro == "CHU_TICH" ? 0 : t.VaiTro == "THU_KY" ? 1 : t.VaiTro == "PHAN_BIEN" ? 2 : 3))
            {
                <div class="member-badge @(tv.DaChamDiem ? "done" : "")">
                    <i class="icon fa-solid @(tv.DaChamDiem ? "fa-circle-check done" : "fa-circle pending")"></i>
                    <span class="name">@tv.TenGiangVien</span>
                    <span class="role">(@tv.VaiTroDisplay)</span>
                </div>
            }
        </div>

        <div class="toolbar-row">
            <div class="filter-item">
                <span class="filter-label">Tìm kiếm</span>
                <input type="text" id="txtSearch" class="toolbar-input" placeholder="Mã đề tài, Tên đề tài, Sinh viên..." style="width: 300px;" />
            </div>
            @if (laHoiDongGiuaKy)
            {
                <div class="hd-note">
                    <i class="fa-solid fa-info-circle"></i> Hội đồng giữa kì - Chấm điểm độc lập
                </div>
            }
        </div>

        <div class="table-responsive">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 50px;"></th>
                            <th style="width: 100px;">Mã đề tài</th>
                            <th>Tên đề tài</th>
                            <th style="width: 140px;">GVHD</th>
                            @if (!laHoiDongGiuaKy)
                            {
                                <th style="width: 100px; text-align: center;">Điểm TB HĐ</th>
                            }
                            <th style="width: 120px;">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @if (Model.DanhSachDeTai.Any())
                        {
                            @foreach (var dt in Model.DanhSachDeTai)
                            {
                                var coTheChamDiem = laHoiDongGiuaKy || dt.DanhSachSinhVien.Any(sv => sv.DiemGVHD.HasValue);

                                <tr class="parent-row" data-id="@dt.IdDeTai">
                                    <td>
                                        <button class="toggle-btn" onclick="toggleRow(this)">
                                            <i class="fa-solid fa-plus"></i>
                                        </button>
                                    </td>
                                    <td><strong>@dt.MaDeTai</strong></td>
                                    <td class="td-ellipsis" title="@dt.TenDeTai">@dt.TenDeTai</td>
                                    <td>@dt.TenGVHD</td>
                                    @if (!laHoiDongGiuaKy)
                                    {
                                        <td style="text-align: center;">
                                            @if (dt.DiemTBHoiDong.HasValue)
                                            {
                                                <span class="status-badge status-approved">@dt.DiemTBHoiDong.Value.ToString("F2")</span>
                                            }
                                            else
                                            {
                                                <span style="color: #9ca3af;">-</span>
                                            }
                                        </td>
                                    }
                                    <td>
                                        @if (dt.DaXacNhan)
                                        {
                                            <span class="status-badge status-approved">Đã xác nhận</span>
                                        }
                                        else if (dt.DaChamDiem)
                                        {
                                            <span class="status-badge status-pending">@(laHoiDongGiuaKy ? "Đã nhận xét" : "Chờ xác nhận")</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-notyet">@(laHoiDongGiuaKy ? "Chưa nhận xét" : "Chưa chấm")</span>
                                        }
                                    </td>
                                </tr>
                                <tr class="detail-row" style="display:none;" data-parent="@dt.IdDeTai">
                                    <td colspan="@(laHoiDongGiuaKy ? 5 : 6)">
                                        <table class="student-table">
                                            <thead>
                                                <tr>
                                                    <th>Mã số sinh viên</th>
                                                    <th>Họ và tên</th>
                                                    @if (!laHoiDongGiuaKy)
                                                    {
                                                        <th style="text-align:center; width:100px;">Điểm GVHD</th>
                                                        <th style="text-align:center; width:100px;">Điểm của bạn</th>
                                                    }
                                                    <th style="width:200px;">Tài liệu báo cáo @(laHoiDongGiuaKy ? "giữa kì" : "")</th>
                                                    <th style="text-align:center; width:150px;">Thao tác</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    var svCount = dt.DanhSachSinhVien.Count;
                                                }
                                                @for (int i = 0; i < svCount; i++)
                                                {
                                                    var sv = dt.DanhSachSinhVien[i];
                                                    <tr>
                                                        <td>@sv.Mssv</td>
                                                        <td><strong>@sv.TenSinhVien</strong></td>
                                                        @if (!laHoiDongGiuaKy)
                                                        {
                                                            <td class="plan-cell">
                                                                @if (sv.DiemGVHD.HasValue)
                                                                {
                                                                    <span class="score-cell">@sv.DiemGVHD.Value.ToString("F1")</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="no-score">Chưa chấm</span>
                                                                }
                                                            </td>
                                                            <td class="plan-cell">
                                                                @if (sv.DiemCuaBan.HasValue)
                                                                {
                                                                    <span class="score-cell">@sv.DiemCuaBan.Value.ToString("F1")</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="no-score">Chưa chấm</span>
                                                                }
                                                            </td>
                                                        }
                                                        <td class="plan-cell">
                                                            @if (!string.IsNullOrEmpty(sv.LinkTaiLieu))
                                                            {
                                                                <a href="@sv.LinkTaiLieu" target="_blank" class="file-link">
                                                                    <i class="fa-solid fa-file-pdf"></i>
                                                                    Xem báo cáo
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="no-score">Chưa có</span>
                                                            }
                                                        </td>
                                                        @if (i == 0)
                                                        {
                                                            <!-- Chỉ hiển thị nút thao tác ở dòng đầu tiên với rowspan -->
                                                            <td rowspan="@svCount" class="plan-cell" style="vertical-align: middle;">
                                                                @if (!dt.DaXacNhan && coTheChamDiem)
                                                                {
                                                                    <a href="@Url.Action("ChamDiem", new { phienBaoVeId = dt.PhienBaoVeId })" class="edit-icon" title="@(laHoiDongGiuaKy ? "Nhận xét đề tài" : "Chấm điểm")">
                                                                        <i class="fa-solid @(laHoiDongGiuaKy ? "fa-comment" : "fa-pen-to-square")"></i>
                                                                    </a>
                                                                }
                                                                else if (!dt.DaXacNhan && !coTheChamDiem)
                                                                {
                                                                    <span class="edit-icon" style="background: #f3f4f6; cursor: not-allowed;" title="Chờ GVHD chấm điểm">
                                                                        <i class="fa-solid fa-lock" style="color: #9ca3af;"></i>
                                                                    </span>
                                                                }
                                                                @if (!laHoiDongGiuaKy)
                                                                {
                                                                    <a href="@Url.Action("BangDiemTongHop", new { phienBaoVeId = dt.PhienBaoVeId })" class="edit-icon btn-bangdiem" title="Bảng điểm tổng hợp">
                                                                        <i class="fa-solid fa-table-cells"></i>
                                                                    </a>
                                                                }
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(laHoiDongGiuaKy ? 5 : 6)">
                                    <div class="empty-state">
                                        <i class="fa-solid fa-folder-open"></i>
                                        <h4>Chưa có đề tài</h4>
                                        <p>Hội đồng chưa được phân đề tài để chấm điểm.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    // Toggle row
    window.toggleRow = function(btn) {
        const tr = btn.closest('tr');
        const nextTr = tr.nextElementSibling;
        const icon = btn.querySelector('i');
        if (nextTr && nextTr.classList.contains('detail-row')) {
            if (nextTr.style.display === 'none') {
                nextTr.style.display = 'table-row';
                icon.classList.remove('fa-plus');
                icon.classList.add('fa-minus');
            } else {
                nextTr.style.display = 'none';
                icon.classList.remove('fa-minus');
                icon.classList.add('fa-plus');
            }
        }
    }

    // Search
    var searchTimeout = null;
    var searchInput = document.getElementById('txtSearch');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                var keyword = searchInput.value.toLowerCase();
                document.querySelectorAll('.parent-row').forEach(function(row) {
                    var match = row.textContent.toLowerCase().indexOf(keyword) > -1;
                    row.style.display = match ? '' : 'none';
                    var detailRow = row.nextElementSibling;
                    if (detailRow && detailRow.classList.contains('detail-row')) {
                        detailRow.style.display = 'none';
                        var toggleIcon = row.querySelector('.toggle-btn i');
                        if (toggleIcon) {
                            toggleIcon.classList.remove('fa-minus');
                            toggleIcon.classList.add('fa-plus');
                        }
                    }
                });
            }, 400);
        });
    }
</script>