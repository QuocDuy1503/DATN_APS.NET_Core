@model DATN_TMS.Areas.GiangVien.Models.BangDiemTongHopViewModel

@{
    var vaiTroDisplay = new Dictionary<string, string>
    {
        { "PHAN_BIEN", "GVPB" },
        { "CHU_TICH", "Chủ tịch" },
        { "THU_KY", "Thư ký" },
        { "UY_VIEN", "Ủy viên" }
    };
    string GetVaiTroShort(string vaiTro) => vaiTroDisplay.ContainsKey(vaiTro) ? vaiTroDisplay[vaiTro] : vaiTro;

    var danhSachThanhVien = Model.DanhSachThanhVienHoiDong;
    var svCount = Model.DanhSachSinhVien.Count;

    // Đánh số thứ tự cho các thành viên cùng vai trò (VD: Ủy viên 1, Ủy viên 2)
    var vaiTroCounters = new Dictionary<string, int>();
    var vaiTroTotals = danhSachThanhVien.GroupBy(t => t.VaiTro).ToDictionary(g => g.Key, g => g.Count());
    var tenCotThanhVien = new Dictionary<int, string>(); // IdGiangVien -> tên cột hiển thị
    foreach (var tv in danhSachThanhVien)
    {
        if (!vaiTroCounters.ContainsKey(tv.VaiTro)) vaiTroCounters[tv.VaiTro] = 0;
        vaiTroCounters[tv.VaiTro]++;
        var shortName = GetVaiTroShort(tv.VaiTro);
        if (vaiTroTotals[tv.VaiTro] > 1)
            tenCotThanhVien[tv.IdGiangVien] = shortName + " " + vaiTroCounters[tv.VaiTro];
        else
            tenCotThanhVien[tv.IdGiangVien] = shortName;
    }

    var daHetHan = Model.DaHetHanBaoCao;
    var conTrongGiaiDoan = Model.ConTrongGiaiDoanBaoCao;
    // Thư ký / Chủ tịch có thể thao tác nếu còn trong giai đoạn báo cáo
    var thuKyCoTheSua = Model.LaThuKy && conTrongGiaiDoan;
    var chuTichCoTheXacNhan = Model.LaChuTich && conTrongGiaiDoan;
}

<style>
    .content-body.chamdiem-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .chamdiem-page .content-card { background: #fff; border-radius: 8px; padding: 20px; box-shadow: 0 0 10px rgba(0,0,0,0.05); min-height: calc(100vh - 140px); }
    .page-header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; flex-wrap: wrap; gap: 12px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }

    /* Breadcrumb */
    .breadcrumb-nav { margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid #f5f5f5; }
    .breadcrumb { display: flex; align-items: center; list-style: none; padding: 0; margin: 0; font-size: 13px; background: transparent; }
    .breadcrumb-item a { color: #6c757d; text-decoration: none; transition: color 0.2s; }
    .breadcrumb-item a:hover { color: #D71920; text-decoration: underline; }
    .breadcrumb-item.active { color: #333; font-weight: 600; cursor: default; }
    .breadcrumb-item + .breadcrumb-item::before { content: "/"; padding: 0 8px; color: #ccc; }

    .info-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 20px; }
    .info-card-header { background: #f8f9fa; padding: 12px 16px; border-bottom: 1px solid #e5e7eb; font-weight: 600; font-size: 14px; color: #374151; display: flex; align-items: center; gap: 8px; }
    .info-card-body { padding: 16px; }
    .info-row { display: flex; gap: 24px; flex-wrap: wrap; }
    .info-item { flex: 1; min-width: 200px; }
    .info-label { font-size: 12px; color: #6b7280; margin-bottom: 4px; }
    .info-value { font-size: 14px; color: #1f2937; font-weight: 500; }

    .status-badge { padding: 5px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; color: #fff; display: inline-flex; align-items: center; gap: 4px; }
    .status-done { background: #16a34a; }
    .status-pending { background: #f59e0b; }
    .status-danger { background: #dc3545; }

    /* Bảng điểm kiểu bảng ngang */
    .score-table-wrap { border: 1px solid #e5e7eb; border-radius: 8px; overflow-x: auto; background: #fff; }
    .score-table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 700px; }
    .score-table thead th { background: #f3f4f6; font-weight: 700; padding: 10px 12px; text-align: center; border: 1px solid #e5e7eb; color: #374151; white-space: nowrap; }
    .score-table thead th.th-group { background: #eef2ff; color: #3730a3; }
    .score-table tbody td { padding: 10px 12px; border: 1px solid #e5e7eb; vertical-align: middle; text-align: center; color: #333; }
    .score-table tbody td.td-left { text-align: left; }
    .score-table tbody td.td-name { font-weight: 600; white-space: nowrap; }
    .score-table tbody td.td-topic { text-align: left; font-weight: 600; max-width: 250px; }
    .score-table .score-val { font-weight: 700; font-size: 14px; }
    .score-table .score-gvhd { color: #0369a1; }
    .score-table .score-hd { color: #374151; }
    .score-table .score-avg { color: #7c3aed; font-size: 16px; font-weight: 800; }
    .score-table .score-na { color: #9ca3af; font-style: italic; font-weight: 400; font-size: 12px; }
    .score-table tfoot td { background: #f0fdf4; font-weight: 700; border: 1px solid #e5e7eb; }

    .legend-row { display: flex; gap: 16px; flex-wrap: wrap; font-size: 12px; color: #6b7280; margin-top: 12px; }
    .legend-item { display: flex; align-items: center; gap: 4px; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

    .alert-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; padding: 12px 16px; border-radius: 6px; font-size: 13px; margin-top: 12px; display: flex; align-items: center; gap: 8px; }
    .alert-info { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; padding: 12px 16px; border-radius: 6px; font-size: 13px; margin-bottom: 16px; }

    .form-group { margin-bottom: 16px; }
    .form-label { font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px; display: block; }
    .form-control { width: 100%; padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 13px; box-sizing: border-box; }
    .form-control:focus { border-color: #0d6efd; outline: none; box-shadow: 0 0 0 2px rgba(13,110,253,0.1); }
    .btn-action { padding: 8px 16px; border-radius: 4px; font-size: 13px; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; border: none; cursor: pointer; }
    .btn-warning { background: #f59e0b; color: #fff; } .btn-warning:hover { background: #d97706; }
    .btn-success { background: #16a34a; color: #fff; } .btn-success:hover { background: #15803d; }

    .history-table { font-size: 12px; }
    .history-table th, .history-table td { padding: 8px 10px; }

    .score-editable { cursor: pointer; position: relative; border-radius: 4px; padding: 2px 6px; transition: background 0.15s; }
    .score-editable:hover { background: #eef2ff; outline: 2px dashed #818cf8; }
    .score-edit-input { width: 60px; padding: 4px 6px; border: 2px solid #818cf8; border-radius: 4px; font-size: 13px; text-align: center; font-weight: 700; }
    .score-edit-input:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.15); }

    /* Cảnh báo chênh lệch điểm */
    .score-warn-member { background: #fef3c7 !important; color: #92400e !important; }
    .score-warn-member .score-val { color: #b45309 !important; }
    .score-warn-gvhd { background: #fee2e2 !important; color: #991b1b !important; }
    .score-warn-gvhd .score-val { color: #dc2626 !important; }
    .score-warn-icon { font-size: 10px; margin-left: 2px; vertical-align: super; }
</style>

<div class="content-body chamdiem-page">
    <div class="content-card">
        <div class="page-header-row">
            <div>
                <h2 class="page-title">Bảng điểm tổng hợp</h2>
            </div>
            @if (Model.DaXacNhan)
            {
                <span class="status-badge status-done" style="font-size: 14px;"><i class="fa-solid fa-check"></i> Đã xác nhận</span>
            }
            else
            {
                <span class="status-badge status-pending" style="font-size: 14px;"><i class="fa-solid fa-clock"></i> Chờ xác nhận</span>
            }
        </div>

        <nav aria-label="breadcrumb" class="breadcrumb-nav">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Danh sách hội đồng</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Detail", new { id = Model.HoiDongId })">@Model.TenHoiDong</a></li>
                <li class="breadcrumb-item active" aria-current="page">Bảng điểm - @Model.MaDeTai</li>
            </ol>
        </nav>

        @if (daHetHan && !conTrongGiaiDoan)
        {
            <div style="background: #fee2e2; border: 1px solid #fca5a5; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; font-size: 13px; color: #991b1b;">
                <i class="fa-solid fa-lock" style="font-size: 16px;"></i>
                <span>Đã hết giai đoạn báo cáo. Bảng điểm chỉ có thể xem, không thể chỉnh sửa.</span>
            </div>
        }
        else if (daHetHan && conTrongGiaiDoan && (Model.LaThuKy || Model.LaChuTich))
        {
            <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; font-size: 13px; color: #856404;">
                <i class="fa-solid fa-circle-exclamation" style="font-size: 16px;"></i>
                <span>Đã hết hạn báo cáo hội đồng. @(Model.LaThuKy ? "Thư ký vẫn có thể chỉnh sửa điểm trên bảng tổng hợp." : "Chủ tịch vẫn có thể xác nhận điểm.")</span>
            </div>
        }

        <!-- Thông tin đề tài -->
        <div class="info-card">
            <div class="info-card-header"><i class="fa-solid fa-file-alt"></i> Thông tin đề tài</div>
            <div class="info-card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label">Mã đề tài</div>
                        <div class="info-value">@Model.MaDeTai</div>
                    </div>
                    <div class="info-item" style="flex: 3;">
                        <div class="info-label">Tên đề tài</div>
                        <div class="info-value">@Model.TenDeTai</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">GVHD</div>
                        <div class="info-value">@Model.TenGVHD</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- BẢNG ĐIỂM KIỂU BẢNG NGANG (theo hình mẫu) -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-table"></i> Bảng điểm chi tiết
                @if (!Model.LaHoiDongGiuaKy)
                {
                    <span style="margin-left: auto; font-weight: normal; font-size: 12px; color: #6b7280;">
                        <i class="fa-solid fa-info-circle"></i> GVHD: 30% — Hội đồng: 70%
                    </span>
                }
            </div>
            <div class="info-card-body" style="padding: 0;">
                <div class="score-table-wrap">
                    <table class="score-table">
                        <thead>
                            <tr>
                                <th rowspan="2" style="min-width: 180px;">Tên đề tài</th>
                                <th rowspan="2" style="min-width: 150px;">Họ và tên SV</th>
                                @if (!Model.LaHoiDongGiuaKy)
                                {
                                    <th rowspan="2">Điểm<br/>GVHD</th>
                                }
                                <th colspan="@danhSachThanhVien.Count" class="th-group">Điểm của hội đồng</th>
                                <th rowspan="2" style="min-width: 110px;">Điểm<br/>trung bình</th>
                            </tr>
                            <tr>
                                @foreach (var tv in danhSachThanhVien)
                                {
                                    <th class="th-group">@tenCotThanhVien[tv.IdGiangVien]</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < svCount; i++)
                            {
                                var svItem = Model.DanhSachSinhVien[i];

                                // Tính chênh lệch điểm giữa các thành viên hội đồng cho SV này
                                var diemThanhVienValues = svItem.DiemTheoThanhVien
                                    .Where(kv => kv.Value.HasValue)
                                    .Select(kv => new { Id = kv.Key, Diem = kv.Value!.Value })
                                    .ToList();
                                double diemMaxHD = diemThanhVienValues.Any() ? diemThanhVienValues.Max(x => x.Diem) : 0;
                                double diemMinHD = diemThanhVienValues.Any() ? diemThanhVienValues.Min(x => x.Diem) : 0;
                                bool coChenhLechThanhVien = diemThanhVienValues.Count > 1 && (diemMaxHD - diemMinHD) > 1;

                                // Tính chênh lệch GVHD vs TB hội đồng
                                double diemTBHD_SV = diemThanhVienValues.Any() ? diemThanhVienValues.Average(x => x.Diem) : 0;
                                bool coChenhLechGVHD = !Model.LaHoiDongGiuaKy && svItem.DiemGVHD > 0
                                    && diemThanhVienValues.Any()
                                    && Math.Abs(svItem.DiemGVHD - diemTBHD_SV) > 2;

                                <tr>
                                    @if (i == 0)
                                    {
                                        <td rowspan="@svCount" class="td-topic">@Model.TenDeTai</td>
                                    }
                                    <td class="td-name">@svItem.TenSinhVien</td>
                                    @if (!Model.LaHoiDongGiuaKy)
                                    {
                                        <td class="@(coChenhLechGVHD ? "score-warn-gvhd" : "")">
                                            @if (svItem.DiemGVHD > 0)
                                            {
                                                <span class="score-val score-gvhd">@svItem.DiemGVHD.ToString("F1")</span>
                                                @if (coChenhLechGVHD)
                                                {
                                                    <i class="fa-solid fa-triangle-exclamation score-warn-icon" title="Chênh lệch > 2 điểm so với TB hội đồng (@diemTBHD_SV.ToString("F1"))"></i>
                                                }
                                            }
                                            else
                                            {
                                                <span class="score-na">—</span>
                                            }
                                        </td>
                                    }
                                    @foreach (var tv in danhSachThanhVien)
                                    {
                                        @if (svItem.DiemTheoThanhVien.ContainsKey(tv.IdGiangVien) && svItem.DiemTheoThanhVien[tv.IdGiangVien].HasValue)
                                        {
                                            var diemVal = svItem.DiemTheoThanhVien[tv.IdGiangVien]!.Value;
                                            // Kiểm tra ô này có phải outlier (chênh lệch > 1 so với thành viên khác)
                                            bool laOutlier = coChenhLechThanhVien && (diemVal == diemMaxHD || diemVal == diemMinHD) && diemMaxHD != diemMinHD;

                                            <td class="@(laOutlier ? "score-warn-member" : "")">
                                                @if (thuKyCoTheSua)
                                                {
                                                    <span class="score-val score-hd score-editable"
                                                          data-phien="@svItem.PhienBaoVeId"
                                                          data-sv="@svItem.IdSinhVien"
                                                          data-nguoicham="@tv.IdGiangVien"
                                                          data-diemcu="@diemVal.ToString("F1")"
                                                          title="Click để chỉnh sửa">@diemVal.ToString("F1")</span>
                                                }
                                                else
                                                {
                                                    <span class="score-val score-hd">@diemVal.ToString("F1")</span>
                                                }
                                                @if (laOutlier)
                                                {
                                                    <i class="fa-solid fa-triangle-exclamation score-warn-icon" title="Chênh lệch > 1 điểm giữa các thành viên (Cao nhất: @diemMaxHD.ToString("F1"), Thấp nhất: @diemMinHD.ToString("F1"))"></i>
                                                }
                                            </td>
                                        }
                                        else
                                        {
                                            <td><span class="score-na">—</span></td>
                                        }
                                    }
                                    <td>
                                        <span class="score-val score-avg">@svItem.DiemTrungBinhCuoi.ToString("F1")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (Model.DiemTongKetCuoi.HasValue)
                        {
                            <tfoot>
                                <tr>
                                    <td colspan="@(2 + (Model.LaHoiDongGiuaKy ? 0 : 1) + danhSachThanhVien.Count)" style="text-align: right;">
                                        <strong>Điểm tổng kết (đã xác nhận):</strong>
                                    </td>
                                    <td><span style="font-size: 18px; font-weight: 800; color: #16a34a;">@Model.DiemTongKetCuoi.Value.ToString("F1")</span></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>

                <!-- Thông tin thành viên HĐ chi tiết -->
                <div style="padding: 12px 16px; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280;">
                    <strong>Thành viên hội đồng:</strong>
                    @foreach (var tv in Model.DiemThanhViens.OrderBy(t => t.VaiTro == "PHAN_BIEN" ? 0 : t.VaiTro == "CHU_TICH" ? 1 : t.VaiTro == "UY_VIEN" ? 2 : 3))
                    {
                        var statusColor = tv.DaChamDiem ? "#16a34a" : "#dc3545";
                        <span style="margin-right: 16px;">
                            <span style="color: @statusColor; font-weight: 600;">●</span>
                            @tv.TenGiangVien <em>(@tv.VaiTroDisplay)</em>
                            — @(tv.DaChamDiem ? "Đã chấm" : "Chưa chấm")
                        </span>
                    }
                </div>

                @if (!Model.LaHoiDongGiuaKy)
                {
                    <div class="legend-row" style="padding: 0 16px 12px;">
                        <div class="legend-item"><span class="legend-dot" style="background: #0369a1;"></span> Điểm GVHD (30%)</div>
                        <div class="legend-item"><span class="legend-dot" style="background: #374151;"></span> Điểm hội đồng (70%)</div>
                        <div class="legend-item"><span class="legend-dot" style="background: #7c3aed;"></span> Điểm TB = GVHD×30% + TB HĐ×70%</div>
                        <div class="legend-item"><span class="legend-dot" style="background: #fef3c7; border: 1px solid #f59e0b;"></span> Chênh lệch > 1 điểm (thành viên HĐ)</div>
                        <div class="legend-item"><span class="legend-dot" style="background: #fee2e2; border: 1px solid #f87171;"></span> Chênh lệch > 2 điểm (GVHD vs TB HĐ)</div>
                    </div>
                }

                @{
                    // Tính tổng hợp cảnh báo cho tất cả sinh viên
                    var tongChenhLechThanhVien = false;
                    var tongChenhLechGVHD = false;
                    foreach (var svCheck in Model.DanhSachSinhVien)
                    {
                        var diemTVCheck = svCheck.DiemTheoThanhVien.Where(kv => kv.Value.HasValue).Select(kv => kv.Value!.Value).ToList();
                        if (diemTVCheck.Count > 1 && (diemTVCheck.Max() - diemTVCheck.Min()) > 1)
                            tongChenhLechThanhVien = true;
                        if (!Model.LaHoiDongGiuaKy && svCheck.DiemGVHD > 0 && diemTVCheck.Any() && Math.Abs(svCheck.DiemGVHD - diemTVCheck.Average()) > 2)
                            tongChenhLechGVHD = true;
                    }
                }

                @if (tongChenhLechThanhVien || tongChenhLechGVHD)
                {
                    <div class="alert-warning" style="margin: 0 16px 12px; flex-direction: column; align-items: flex-start; gap: 6px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <strong>Phát hiện chênh lệch điểm:</strong>
                        </div>
                        @if (tongChenhLechThanhVien)
                        {
                            <div style="padding-left: 24px; font-size: 12px;">
                                <span style="background: #fef3c7; padding: 2px 8px; border-radius: 4px; border: 1px solid #f59e0b; margin-right: 4px;">⚠</span>
                                Điểm giữa các thành viên hội đồng chênh lệch <strong>hơn 1 điểm</strong>. Thư ký cần điều chỉnh thống nhất.
                            </div>
                        }
                        @if (tongChenhLechGVHD)
                        {
                            <div style="padding-left: 24px; font-size: 12px;">
                                <span style="background: #fee2e2; padding: 2px 8px; border-radius: 4px; border: 1px solid #f87171; margin-right: 4px;">⚠</span>
                                Điểm GVHD chênh lệch <strong>hơn 2 điểm</strong> so với điểm trung bình hội đồng.
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Điều chỉnh / Xác nhận -->
        @if ((thuKyCoTheSua || chuTichCoTheXacNhan) && !Model.LaHoiDongGiuaKy)
        {
            <div class="info-card">
                <div class="info-card-header">
                    @if (thuKyCoTheSua)
                    {
                        <i class="fa-solid fa-pen"></i> <span>Điều chỉnh điểm (Thư ký)</span>
                    }
                    else
                    {
                        <i class="fa-solid fa-check-double"></i> <span>Xác nhận điểm (Chủ tịch)</span>
                    }
                </div>
                <div class="info-card-body">
                    @if (thuKyCoTheSua && Model.CoChenhLechLon)
                    {
                        <form id="formDieuChinhDiem">
                            <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Điểm mới (sau khi thống nhất)</label>
                                    <input type="number" class="form-control" id="diemMoi" min="0" max="10" step="0.1" value="@Model.DiemTBHoiDong.ToString("F1")" />
                                </div>
                                <div class="form-group" style="flex: 2; min-width: 300px;">
                                    <label class="form-label">Lý do điều chỉnh</label>
                                    <textarea class="form-control" id="lyDoDieuChinh" rows="2" placeholder="Nhập lý do thống nhất điểm..."></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn-action btn-warning"><i class="fa-solid fa-pen"></i> Điều chỉnh điểm</button>
                        </form>
                    }

                    @if (chuTichCoTheXacNhan)
                    {
                        var tatCaDaCham = Model.DiemThanhViens.All(t => t.DaChamDiem);
                        if (!tatCaDaCham)
                        {
                            <div class="alert-info">
                                <i class="fa-solid fa-info-circle"></i> Chưa thể xác nhận vì còn thành viên chưa chấm điểm.
                            </div>
                        }
                        else
                        {
                            <form id="formXacNhanDiem">
                                <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                                    <div class="form-group" style="flex: 1; min-width: 150px;">
                                        <label class="form-label">Điểm tổng kết cuối cùng</label>
                                        <input type="number" class="form-control" id="diemTongKet" min="0" max="10" step="0.1" value="@(Model.DiemTongKetCuoi?.ToString("F1") ?? Model.DiemTBHoiDong.ToString("F1"))" />
                                    </div>
                                    <div class="form-group" style="flex: 2; min-width: 300px;">
                                        <label class="form-label">Ghi chú</label>
                                        <textarea class="form-control" id="ghiChuXacNhan" rows="2" placeholder="Ghi chú xác nhận (nếu có)...">@Model.GhiChuXacNhan</textarea>
                                    </div>
                                </div>
                                <button type="submit" class="btn-action btn-success">
                                    <i class="fa-solid fa-check"></i> @(Model.DaXacNhan ? "Xác nhận lại điểm" : "Xác nhận điểm")
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        }

        <!-- Lịch sử cập nhật -->
        @if (Model.LichSuCapNhat.Any())
        {
            <div class="info-card">
                <div class="info-card-header"><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử cập nhật</div>
                <div class="info-card-body" style="padding: 0;">
                    <div class="score-table-wrap history-table" style="border: none; border-radius: 0;">
                        <table class="score-table" style="min-width: auto;">
                            <thead>
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Người cập nhật</th>
                                    <th>Loại</th>
                                    <th>Điểm cũ</th>
                                    <th>Điểm mới</th>
                                    <th>Lý do</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ls in Model.LichSuCapNhat)
                                {
                                    <tr>
                                        <td>@ls.NgayCapNhat?.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="td-left">@ls.TenNguoiCapNhat</td>
                                        <td>
                                            <span class="status-badge @(ls.LoaiCapNhat == "CHU_TICH_XAC_NHAN" ? "status-done" : "status-pending")">
                                                @ls.LoaiCapNhatDisplay
                                            </span>
                                        </td>
                                        <td>@(ls.DiemCu?.ToString("F1") ?? "—")</td>
                                        <td>@(ls.DiemMoi?.ToString("F1") ?? "—")</td>
                                        <td class="td-left">@ls.LyDo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@Html.AntiForgeryToken()
