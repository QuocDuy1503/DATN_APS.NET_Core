@model DATN_TMS.Areas.GiangVien.Models.BangDiemTongHopViewModel

<style>
    .content-body.chamdiem-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .chamdiem-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); min-height: calc(100vh - 140px);
    }
    .page-header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; }
    .page-description { font-size: 13px; color: #6c757d; margin-top: 4px; }

    .btn-back { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; padding: 8px 14px; border-radius: 6px; font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 12px; }
    .btn-back:hover { background: #e5e7eb; color: #1f2937; }

    .info-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 20px; }
    .info-card-header { background: #f8f9fa; padding: 12px 16px; border-bottom: 1px solid #e5e7eb; font-weight: 600; font-size: 14px; color: #374151; display: flex; align-items: center; gap: 8px; }
    .info-card-body { padding: 16px; }

    .info-row { display: flex; gap: 24px; flex-wrap: wrap; }
    .info-item { flex: 1; min-width: 200px; }
    .info-label { font-size: 12px; color: #6b7280; margin-bottom: 4px; }
    .info-value { font-size: 14px; color: #1f2937; font-weight: 500; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { background: #f3f4f6; font-weight: 700 !important; padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; color: #444; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; color: #333; }
    tbody tr:hover { background: #f9f9f9; }
    tbody tr.row-info { background: #dbeafe; }
    tfoot td { background: #f8f9fa; padding: 12px; font-weight: 600; }
    tfoot tr.row-success td { background: #dcfce7; }

    .status-badge { padding: 5px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; color: #fff; display: inline-flex; align-items: center; gap: 4px; }
    .status-info { background: #17a2b8; }
    .status-done { background: #16a34a; }
    .status-pending { background: #f59e0b; }
    .status-danger { background: #dc3545; }
    .status-secondary { background: #6c757d; }
    .status-primary { background: #0d6efd; }

    .alert-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; padding: 12px 16px; border-radius: 6px; font-size: 13px; margin-top: 12px; display: flex; align-items: center; gap: 8px; }
    .alert-info { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; padding: 12px 16px; border-radius: 6px; font-size: 13px; margin-bottom: 16px; }

    .form-group { margin-bottom: 16px; }
    .form-label { font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px; display: block; }
    .form-control { width: 100%; padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 13px; }
    .form-control:focus { border-color: #0d6efd; outline: none; box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.1); }

    .btn-action { padding: 8px 16px; border-radius: 4px; font-size: 13px; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; border: none; cursor: pointer; }
    .btn-warning { background: #f59e0b; color: #fff; }
    .btn-warning:hover { background: #d97706; }
    .btn-success { background: #16a34a; color: #fff; }
    .btn-success:hover { background: #15803d; }

    .history-table { font-size: 12px; }
    .history-table th, .history-table td { padding: 8px 10px; }
</style>

<div class="content-body chamdiem-page">
    <div class="content-card">
        <a href="@Url.Action("Detail", new { id = Model.HoiDongId })" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>

        <div class="page-header-row">
            <div>
                <h2 class="page-title">Bảng điểm tổng hợp</h2>
                <p class="page-description">@Model.TenHoiDong</p>
            </div>
            @if (Model.DaXacNhan)
            {
                <span class="status-badge status-done" style="font-size: 14px;"><i class="fa-solid fa-check"></i> Đã xác nhận</span>
            }
            else
            {
                <span class="status-badge status-pending" style="font-size: 14px;"><i class="fa-solid fa-clock"></i> Chờ xác nhận</span>
            }
        </div>

        <!-- Thông tin sinh viên -->
        <div class="info-card">
            <div class="info-card-header"><i class="fa-solid fa-user"></i> Thông tin sinh viên</div>
            <div class="info-card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label">Họ tên</div>
                        <div class="info-value">@Model.TenSinhVien</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">MSSV</div>
                        <div class="info-value">@Model.Mssv</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Đề tài</div>
                        <div class="info-value">@Model.TenDeTai</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Mã đề tài</div>
                        <div class="info-value">@Model.MaDeTai</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng điểm -->
        <div class="info-card">
            <div class="info-card-header"><i class="fa-solid fa-table"></i> Bảng điểm chi tiết</div>
            <div class="info-card-body" style="padding: 0;">
                <div class="table-responsive" style="border: none; border-radius: 0;">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 200px;">Người chấm</th>
                                <th style="width: 120px;">Vai trò</th>
                                <th style="width: 120px;">Trạng thái</th>
                                <th style="width: 100px;">Tổng điểm</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Điểm GVHD -->
                            <tr class="row-info">
                                <td><strong>@Model.TenGVHD</strong></td>
                                <td><span class="status-badge status-info">GVHD</span></td>
                                <td>
                                    @if (Model.DiemGVHD > 0)
                                    {
                                        <span class="status-badge status-done"><i class="fa-solid fa-check"></i> Đã chấm</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-pending">Chưa chấm</span>
                                    }
                                </td>
                                <td><span style="font-size: 16px; font-weight: 700; color: #17a2b8;">@Model.DiemGVHD.ToString("F1")</span></td>
                            </tr>

                            <!-- Điểm các thành viên hội đồng -->
                            @foreach (var tv in Model.DiemThanhViens.OrderBy(t => t.VaiTro == "CHU_TICH" ? 0 : t.VaiTro == "THU_KY" ? 1 : 2))
                            {
                                <tr>
                                    <td><strong>@tv.TenGiangVien</strong></td>
                                    <td><span class="status-badge status-secondary">@tv.VaiTroDisplay</span></td>
                                    <td>
                                        @if (tv.DaChamDiem)
                                        {
                                            <span class="status-badge status-done"><i class="fa-solid fa-check"></i> Đã chấm</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-danger">Chưa chấm</span>
                                        }
                                    </td>
                                    <td>
                                        @if (tv.DaChamDiem)
                                        {
                                            <span style="font-size: 16px; font-weight: 700;">@tv.TongDiem.ToString("F1")</span>
                                        }
                                        else
                                        {
                                            <span style="color: #9ca3af;">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" style="text-align: right;"><strong>Điểm trung bình Hội đồng:</strong></td>
                                <td><span style="font-size: 20px; font-weight: 700; color: #0d6efd;">@Model.DiemTBHoiDong.ToString("F2")</span></td>
                            </tr>
                            @if (Model.DiemTongKetCuoi.HasValue)
                            {
                                <tr class="row-success">
                                    <td colspan="3" style="text-align: right;"><strong>Điểm tổng kết (đã xác nhận):</strong></td>
                                    <td><span style="font-size: 20px; font-weight: 700; color: #16a34a;">@Model.DiemTongKetCuoi.Value.ToString("F1")</span></td>
                                </tr>
                            }
                        </tfoot>
                    </table>
                </div>

                @if (Model.CoChenhLechLon)
                {
                    <div class="alert-warning" style="margin: 16px;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span><strong>Cảnh báo:</strong> Phát hiện chênh lệch điểm lớn (> 1 điểm giữa các thành viên HĐ hoặc > 2 điểm với GVHD). Thư ký cần điều chỉnh và thống nhất điểm trước khi Chủ tịch xác nhận.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Phần điều chỉnh/xác nhận -->
        @if ((Model.LaThuKy || Model.LaChuTich) && !Model.DaXacNhan)
        {
            <div class="info-card">
                <div class="info-card-header">
                    @if (Model.LaThuKy)
                    {
                        <i class="fa-solid fa-pen"></i> <span>Điều chỉnh điểm (Thư ký)</span>
                    }
                    else
                    {
                        <i class="fa-solid fa-check-double"></i> <span>Xác nhận điểm (Chủ tịch)</span>
                    }
                </div>
                <div class="info-card-body">
                    @if (Model.LaThuKy && Model.CoChenhLechLon)
                    {
                        <form id="formDieuChinhDiem">
                            <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Điểm mới (sau khi thống nhất)</label>
                                    <input type="number" class="form-control" id="diemMoi" min="0" max="10" step="0.1" value="@Model.DiemTBHoiDong.ToString("F1")" />
                                </div>
                                <div class="form-group" style="flex: 2; min-width: 300px;">
                                    <label class="form-label">Lý do điều chỉnh</label>
                                    <textarea class="form-control" id="lyDoDieuChinh" rows="2" placeholder="Nhập lý do thống nhất điểm..."></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn-action btn-warning"><i class="fa-solid fa-pen"></i> Điều chỉnh điểm</button>
                        </form>
                    }

                    @if (Model.LaChuTich)
                    {
                        var tatCaDaCham = Model.DiemThanhViens.All(t => t.DaChamDiem);
                        @if (!tatCaDaCham)
                        {
                            <div class="alert-info">
                                <i class="fa-solid fa-info-circle"></i> Chưa thể xác nhận vì còn thành viên chưa chấm điểm.
                            </div>
                        }
                        else
                        {
                            <form id="formXacNhanDiem">
                                <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                                    <div class="form-group" style="flex: 1; min-width: 150px;">
                                        <label class="form-label">Điểm tổng kết cuối cùng</label>
                                        <input type="number" class="form-control" id="diemTongKet" min="0" max="10" step="0.1" value="@Model.DiemTBHoiDong.ToString("F1")" />
                                    </div>
                                    <div class="form-group" style="flex: 2; min-width: 300px;">
                                        <label class="form-label">Ghi chú</label>
                                        <textarea class="form-control" id="ghiChuXacNhan" rows="2" placeholder="Ghi chú xác nhận (nếu có)..."></textarea>
                                    </div>
                                </div>
                                <button type="submit" class="btn-action btn-success"><i class="fa-solid fa-check"></i> Xác nhận điểm</button>
                            </form>
                        }
                    }
                </div>
            </div>
        }

        <!-- Lịch sử cập nhật -->
        @if (Model.LichSuCapNhat.Any())
        {
            <div class="info-card">
                <div class="info-card-header"><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử cập nhật</div>
                <div class="info-card-body" style="padding: 0;">
                    <div class="table-responsive history-table" style="border: none; border-radius: 0;">
                        <table>
                            <thead>
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Người cập nhật</th>
                                    <th>Loại</th>
                                    <th>Điểm cũ</th>
                                    <th>Điểm mới</th>
                                    <th>Lý do</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ls in Model.LichSuCapNhat)
                                {
                                    <tr>
                                        <td>@ls.NgayCapNhat?.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@ls.TenNguoiCapNhat</td>
                                        <td>
                                            <span class="status-badge @(ls.LoaiCapNhat == "CHU_TICH_XAC_NHAN" ? "status-done" : "status-pending")">
                                                @ls.LoaiCapNhatDisplay
                                            </span>
                                        </td>
                                        <td>@(ls.DiemCu?.ToString("F1") ?? "-")</td>
                                        <td>@(ls.DiemMoi?.ToString("F1") ?? "-")</td>
                                        <td>@ls.LyDo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
