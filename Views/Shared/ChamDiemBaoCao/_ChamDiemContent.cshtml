@model DATN_TMS.Areas.GiangVien.Models.ChamDiemPhienBaoVeViewModel

<style>
    .content-body.chamdiem-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .chamdiem-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); min-height: calc(100vh - 140px);
    }
    .page-header-row { margin-bottom: 20px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; }
    .page-description { font-size: 13px; color: #6c757d; margin-top: 4px; }

    .btn-back { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; padding: 8px 14px; border-radius: 6px; font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 12px; }
    .btn-back:hover { background: #e5e7eb; color: #1f2937; }

    .info-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 20px; }
    .info-card-header { background: #f8f9fa; padding: 12px 16px; border-bottom: 1px solid #e5e7eb; font-weight: 600; font-size: 14px; color: #374151; display: flex; align-items: center; gap: 8px; }
    .info-card-body { padding: 16px; }

    .info-row { display: flex; gap: 24px; flex-wrap: wrap; }
    .info-item { flex: 1; min-width: 200px; }
    .info-label { font-size: 12px; color: #6b7280; margin-bottom: 4px; }
    .info-value { font-size: 14px; color: #1f2937; font-weight: 500; }

    .alert-info { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; padding: 12px 16px; border-radius: 6px; font-size: 13px; margin-top: 12px; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { background: #f3f4f6; font-weight: 700 !important; padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; color: #444; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; color: #333; }
    tbody tr:hover { background: #f9f9f9; }
    tfoot td { background: #f8f9fa; padding: 12px; font-weight: 600; }

    .diem-input { width: 80px; padding: 6px 10px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 13px; text-align: center; font-weight: 600; }
    .diem-input:focus { border-color: #0d6efd; outline: none; box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.1); }
    .nhanxet-input { width: 100%; padding: 6px 10px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 13px; resize: vertical; }
    .nhanxet-input:focus { border-color: #0d6efd; outline: none; }

    .status-badge { padding: 5px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; color: #fff; display: inline-flex; align-items: center; gap: 4px; }
    .status-info { background: #17a2b8; }
    .status-done { background: #16a34a; }

    .btn-action { padding: 8px 16px; border-radius: 4px; font-size: 13px; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; border: none; cursor: pointer; }
    .btn-primary { background: #0d6efd; color: #fff; }
    .btn-primary:hover { background: #0b5ed7; }
    .btn-secondary { background: #6c757d; color: #fff; }
    .btn-secondary:hover { background: #5a6268; }

    .form-footer { display: flex; justify-content: flex-end; gap: 12px; margin-top: 20px; }
</style>

<div class="content-body chamdiem-page">
    <div class="content-card">
        <a href="@Url.Action("Detail", new { id = Model.HoiDongId })" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>

        <div class="page-header-row">
            <h2 class="page-title">@(Model.ChiNhanXet ? "Nhận xét" : "Chấm điểm") sinh viên - @Model.LoaiHoiDongDisplay</h2>
            <p class="page-description">@Model.TenHoiDong</p>
        </div>

        <!-- Thông tin phiếu chấm -->
        <div class="alert-info" style="margin-bottom: 16px; display: flex; align-items: center; gap: 12px;">
            <i class="fa-solid fa-file-alt" style="font-size: 20px;"></i>
            <div>
                <strong>Loại phiếu:</strong> @Model.TenLoaiPhieu<br/>
                <small>Vai trò: <strong>@Model.VaiTroDisplay</strong></small>
            </div>
            @if (Model.ChiNhanXet)
            {
                <span class="status-badge" style="margin-left: auto; background: #fef3c7; color: #92400e;">
                    <i class="fa-solid fa-comment"></i> Chỉ nhận xét
                </span>
            }
        </div>

        <!-- Thông tin sinh viên -->
        <div class="info-card">
            <div class="info-card-header">
                <i class="fa-solid fa-user"></i> Thông tin đề tài và sinh viên
                @if (Model.DaChamDiem)
                {
                    <span class="status-badge status-done" style="margin-left: auto;"><i class="fa-solid fa-check"></i> Đã @(Model.ChiNhanXet ? "nhận xét" : "chấm") - Có thể sửa</span>
                }
            </div>
            <div class="info-card-body">
                <div class="info-row" style="margin-bottom: 16px;">
                    <div class="info-item" style="flex: 2;">
                        <div class="info-label">Đề tài</div>
                        <div class="info-value">
                            <strong>@Model.MaDeTai</strong> - @Model.TenDeTai
                        </div>
                    </div>
                </div>

                <!-- Danh sách sinh viên -->
                @if (Model.DanhSachSinhVien.Count > 1)
                {
                    <div style="background: #f0fdf4; border: 1px solid #86efac; border-radius: 6px; padding: 12px; margin-bottom: 12px;">
                        <i class="fa-solid fa-users" style="color: #16a34a;"></i>
                        <strong style="color: #166534;">Đề tài có @Model.DanhSachSinhVien.Count sinh viên</strong>
                        @if (Model.LaHoiDongGiuaKy)
                        {
                            <span style="color: #6b7280; font-size: 12px;"> - Nhận xét chung áp dụng cho cả đề tài</span>
                        }
                        else
                        {
                            <span style="color: #6b7280; font-size: 12px;"> - Vui lòng chấm điểm riêng cho từng sinh viên</span>
                        }
                    </div>
                }

                <table style="width: 100%; font-size: 13px; border-collapse: collapse;">
                    <thead>
                        <tr style="background: #f3f4f6;">
                            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #e5e7eb;">MSSV</th>
                            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #e5e7eb;">Họ tên</th>
                            @if (!Model.LaHoiDongGiuaKy && !Model.ChiNhanXet)
                            {
                                <th style="padding: 10px; text-align: center; border-bottom: 1px solid #e5e7eb;">Điểm GVHD</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sv in Model.DanhSachSinhVien)
                        {
                            <tr>
                                <td style="padding: 10px; border-bottom: 1px solid #f1f5f9;">@sv.Mssv</td>
                                <td style="padding: 10px; border-bottom: 1px solid #f1f5f9;"><strong>@sv.TenSinhVien</strong></td>
                                @if (!Model.LaHoiDongGiuaKy && !Model.ChiNhanXet)
                                {
                                    <td style="padding: 10px; text-align: center; border-bottom: 1px solid #f1f5f9;">
                                        <span class="status-badge status-info">@(sv.DiemGVHD?.ToString("F1") ?? "-")</span>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.LaHoiDongGiuaKy && !string.IsNullOrEmpty(Model.NhanXetGVHD))
                {
                    <div class="alert-info" style="margin-top: 12px;">
                        <strong>Nhận xét GVHD:</strong> @Model.NhanXetGVHD
                    </div>
                }
                @if (Model.LaHoiDongGiuaKy)
                {
                    <div class="alert-info" style="margin-top: 12px; background: #fef3c7; color: #92400e; border-color: #fcd34d;">
                        <i class="fa-solid fa-info-circle"></i> <strong>Hội đồng Giữa kì:</strong> Chỉ ghi nhận xét về tiến độ đề tài. Nhận xét sẽ áp dụng chung cho tất cả sinh viên trong đề tài.
                    </div>
                }
                @if (Model.LaPhanBien && !Model.LaHoiDongGiuaKy)
                {
                    <div class="alert-info" style="margin-top: 12px; background: #e0f2fe; color: #0369a1; border-color: #7dd3fc;">
                        <i class="fa-solid fa-user-tie"></i> <strong>Phản biện:</strong> Bạn đang sử dụng phiếu chấm phản biện với tiêu chí riêng.
                    </div>
                }
            </div>
        </div>

        <!-- Form chấm điểm/nhận xét -->
        <form id="formChamDiem">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PhienBaoVeId" value="@Model.PhienBaoVeId" />
            <input type="hidden" name="IdDeTai" value="@Model.IdDeTai" />

            @if (Model.LaHoiDongGiuaKy)
            {
                <!-- HỘI ĐỒNG GIỮA KÌ: Form nhận xét CHUNG cho cả đề tài -->
                var svFirst = Model.DanhSachSinhVien.FirstOrDefault();
                var tieuChiList = svFirst?.DiemDaCham?.Any() == true ? svFirst.DiemDaCham : Model.TieuChis;
                <div class="info-card">
                    <div class="info-card-header">
                        <i class="fa-solid fa-comment"></i> 
                        Phiếu nhận xét giữa kì - Đề tài @Model.MaDeTai
                        @if (Model.DaChamDiem)
                        {
                            <span class="status-badge status-done" style="margin-left: auto;"><i class="fa-solid fa-check"></i> Đã nhận xét - Có thể sửa</span>
                        }
                    </div>
                    <div class="info-card-body" style="padding: 0;">
                        @* Lưu thông tin tất cả sinh viên *@
                        @for (int svIndex = 0; svIndex < Model.DanhSachSinhVien.Count; svIndex++)
                        {
                            var sv = Model.DanhSachSinhVien[svIndex];
                            <input type="hidden" name="DanhSachDiemSinhVien[@svIndex].PhienBaoVeId" value="@sv.PhienBaoVeId" />
                            <input type="hidden" name="DanhSachDiemSinhVien[@svIndex].IdSinhVien" value="@sv.IdSinhVien" />
                        }

                        <div class="table-responsive" style="border: none; border-radius: 0;">
                            <table>
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">STT</th>
                                        <th>Tiêu chí đánh giá</th>
                                        <th>Nhận xét</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (tieuChiList != null && tieuChiList.Any())
                                    {
                                        for (int tcIndex = 0; tcIndex < tieuChiList.Count; tcIndex++)
                                        {
                                            var tc = tieuChiList[tcIndex];
                                            <tr>
                                                <td style="text-align: center;">@(tcIndex + 1)</td>
                                                <td>
                                                    <strong>@tc.TenTieuChi</strong>
                                                    @if (!string.IsNullOrEmpty(tc.MoTaHuongDan))
                                                    {
                                                        <br /><small style="color: #6b7280;">@tc.MoTaHuongDan</small>
                                                    }
                                                </td>
                                                <td>
                                                    @* Hidden fields cho tất cả sinh viên (cùng tiêu chí) *@
                                                    @for (int svIndex = 0; svIndex < Model.DanhSachSinhVien.Count; svIndex++)
                                                    {
                                                        <input type="hidden" name="DanhSachDiemSinhVien[@svIndex].DiemChiTiets[@tcIndex].IdTieuChi" value="@tc.Id" />
                                                        <input type="hidden" name="DanhSachDiemSinhVien[@svIndex].DiemChiTiets[@tcIndex].DiemSo" value="0" />
                                                    }
                                                    <textarea class="nhanxet-input nhanxet-chung" 
                                                              data-tc-index="@tcIndex"
                                                              rows="3"
                                                              placeholder="Nhận xét về tiêu chí này..."
                                                              required>@tc.NhanXetDaCham</textarea>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else if (Model.DanhSachSinhVien.Count > 1)
            {
                <!-- HỘI ĐỒNG CUỐI KÌ VỚI NHIỀU SINH VIÊN: Grid tiêu chí (hàng) × sinh viên (cột) -->
                <div class="info-card">
                    <div class="info-card-header">
                        <i class="fa-solid fa-clipboard-check"></i>
                        @(Model.ChiNhanXet ? "Phiếu nhận xét" : "Phiếu chấm điểm") - Tất cả sinh viên
                        @if (Model.DaChamDiem)
                        {
                            <span class="status-badge status-done" style="margin-left: auto;"><i class="fa-solid fa-check"></i> Đã @(Model.ChiNhanXet ? "nhận xét" : "chấm") - Có thể sửa</span>
                        }
                    </div>
                    <div class="info-card-body" style="padding: 0;">
                        @for (int svIndex = 0; svIndex < Model.DanhSachSinhVien.Count; svIndex++)
                        {
                            var svHidden = Model.DanhSachSinhVien[svIndex];
                            <input type="hidden" name="DanhSachDiemSinhVien[@svIndex].PhienBaoVeId" value="@svHidden.PhienBaoVeId" />
                            <input type="hidden" name="DanhSachDiemSinhVien[@svIndex].IdSinhVien" value="@svHidden.IdSinhVien" />
                        }

                        <div class="table-responsive" style="border: none; border-radius: 0; overflow-x: auto;">
                            <table style="min-width: 700px;">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">STT</th>
                                        <th style="min-width: 200px;">Tiêu chí đánh giá</th>
                                        @foreach (var svHead in Model.DanhSachSinhVien)
                                        {
                                            <th style="text-align: center; min-width: 180px; background: #eef2ff;">
                                                <div><strong>@svHead.TenSinhVien</strong></div>
                                                <div style="font-size: 11px; font-weight: 400; color: #6b7280;">@svHead.Mssv</div>
                                                @if (!Model.LaHoiDongGiuaKy && !Model.ChiNhanXet && svHead.DiemGVHD.HasValue)
                                                {
                                                    <div style="margin-top: 4px;">
                                                        <span class="status-badge status-info" style="font-size: 10px;">GVHD: @svHead.DiemGVHD.Value.ToString("F1")</span>
                                                    </div>
                                                }
                                            </th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var firstSV = Model.DanhSachSinhVien.FirstOrDefault();
                                        var tieuChiCount = firstSV?.DiemDaCham?.Count ?? Model.TieuChis?.Count ?? 0;
                                    }
                                    @for (int tcIndex = 0; tcIndex < tieuChiCount; tcIndex++)
                                    {
                                        var tcInfo = firstSV?.DiemDaCham?.ElementAtOrDefault(tcIndex) ?? Model.TieuChis?.ElementAtOrDefault(tcIndex);
                                        if (tcInfo == null) continue;
                                        <tr>
                                            <td style="text-align: center;">@(tcIndex + 1)</td>
                                            <td>
                                                <strong>@tcInfo.TenTieuChi</strong>
                                                @if (!string.IsNullOrEmpty(tcInfo.MoTaHuongDan))
                                                {
                                                    <br /><small style="color: #6b7280;">@tcInfo.MoTaHuongDan</small>
                                                }
                                                @if (!Model.ChiNhanXet)
                                                {
                                                    <br /><small style="color: #2563eb; font-weight: 500;">Trọng số: @tcInfo.TrongSo% — Tối đa: @tcInfo.DiemToiDa.ToString("F1")</small>
                                                }
                                            </td>
                                            @for (int svIdx = 0; svIdx < Model.DanhSachSinhVien.Count; svIdx++)
                                            {
                                                var svData = Model.DanhSachSinhVien[svIdx];
                                                var tcData = svData.DiemDaCham?.ElementAtOrDefault(tcIndex);
                                                <td style="text-align: center; vertical-align: top; padding: 8px;">
                                                    @if (!Model.ChiNhanXet)
                                                    {
                                                        <input type="hidden" name="DanhSachDiemSinhVien[@svIdx].DiemChiTiets[@tcIndex].IdTieuChi" value="@(tcData?.Id ?? tcInfo.Id)" />
                                                        <input type="number"
                                                               class="diem-input diem-sv-@svIdx"
                                                               name="DanhSachDiemSinhVien[@svIdx].DiemChiTiets[@tcIndex].DiemSo"
                                                               value="@(tcData?.DiemDaCham)"
                                                               min="0"
                                                               max="@(tcData?.DiemToiDa ?? tcInfo.DiemToiDa)"
                                                               step="0.1"
                                                               data-max="@(tcData?.DiemToiDa ?? tcInfo.DiemToiDa)"
                                                               data-trongso="@(tcData?.TrongSo ?? tcInfo.TrongSo)"
                                                               required />
                                                        <span style="font-size: 11px; color: #9ca3af; display: block;">/ @((tcData?.DiemToiDa ?? tcInfo.DiemToiDa).ToString("F1"))</span>
                                                    }
                                                    else
                                                    {
                                                        <input type="hidden" name="DanhSachDiemSinhVien[@svIdx].DiemChiTiets[@tcIndex].IdTieuChi" value="@(tcData?.Id ?? tcInfo.Id)" />
                                                        <input type="hidden" name="DanhSachDiemSinhVien[@svIdx].DiemChiTiets[@tcIndex].DiemSo" value="0" />
                                                    }
                                                    <textarea class="nhanxet-input"
                                                              name="DanhSachDiemSinhVien[@svIdx].DiemChiTiets[@tcIndex].NhanXet"
                                                              rows="2"
                                                              style="margin-top: 4px; font-size: 12px;"
                                                              placeholder="Nhận xét...">@(tcData?.NhanXetDaCham)</textarea>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                                @if (!Model.ChiNhanXet)
                                {
                                    <tfoot>
                                        <tr>
                                            <td colspan="2" style="text-align: right;"><strong>Tổng điểm:</strong></td>
                                            @for (int svIdx = 0; svIdx < Model.DanhSachSinhVien.Count; svIdx++)
                                            {
                                                <td style="text-align: center;">
                                                    <span class="tongDiem-sv-@svIdx" style="font-size: 18px; color: #0d6efd; font-weight: 700;">0.0</span>
                                                    <span style="color: #6b7280;"> / 10</span>
                                                </td>
                                            }
                                        </tr>
                                    </tfoot>
                                }
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Form đơn giản cho 1 sinh viên -->
                var sv = Model.DanhSachSinhVien.FirstOrDefault();
                if (sv != null)
                {
                    <div class="info-card">
                        <div class="info-card-header">
                            <i class="fa-solid fa-clipboard-check"></i> 
                            @(Model.ChiNhanXet ? "Phiếu nhận xét" : "Phiếu chấm điểm") - @sv.TenSinhVien (@sv.Mssv)
                        </div>
                        <div class="info-card-body" style="padding: 0;">
                            <input type="hidden" name="DanhSachDiemSinhVien[0].PhienBaoVeId" value="@sv.PhienBaoVeId" />
                            <input type="hidden" name="DanhSachDiemSinhVien[0].IdSinhVien" value="@sv.IdSinhVien" />

                            <div class="table-responsive" style="border: none; border-radius: 0;">
                                <table>
                                    <thead>
                                        <tr>
                                            <th style="width: 50px;">STT</th>
                                            <th>Tiêu chí</th>
                                            @if (!Model.ChiNhanXet)
                                            {
                                                <th style="width: 80px;">Trọng số</th>
                                                <th style="width: 100px;">Điểm tối đa</th>
                                                <th style="width: 100px;">Điểm chấm</th>
                                            }
                                            <th style="@(Model.ChiNhanXet ? "" : "width: 200px;")">Nhận xét</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int tcIndex = 0; tcIndex < sv.DiemDaCham.Count; tcIndex++)
                                        {
                                            var tc = sv.DiemDaCham[tcIndex];
                                            <tr>
                                                <td style="text-align: center;">@(tcIndex + 1)</td>
                                                <td>
                                                    <strong>@tc.TenTieuChi</strong>
                                                    @if (!string.IsNullOrEmpty(tc.MoTaHuongDan))
                                                    {
                                                        <br /><small style="color: #6b7280;">@tc.MoTaHuongDan</small>
                                                    }
                                                </td>
                                                @if (!Model.ChiNhanXet)
                                                {
                                                    <td style="text-align: center;">@tc.TrongSo%</td>
                                                    <td style="text-align: center;">@tc.DiemToiDa.ToString("F1")</td>
                                                    <td>
                                                        <input type="hidden" name="DanhSachDiemSinhVien[0].DiemChiTiets[@tcIndex].IdTieuChi" value="@tc.Id" />
                                                        <input type="number" 
                                                               class="diem-input diem-sv-0" 
                                                               name="DanhSachDiemSinhVien[0].DiemChiTiets[@tcIndex].DiemSo"
                                                               value="@tc.DiemDaCham"
                                                               min="0" 
                                                               max="@tc.DiemToiDa" 
                                                               step="0.1"
                                                               data-max="@tc.DiemToiDa"
                                                               data-trongso="@tc.TrongSo"
                                                               required />
                                                    </td>
                                                }
                                                else
                                                {
                                                    <input type="hidden" name="DanhSachDiemSinhVien[0].DiemChiTiets[@tcIndex].IdTieuChi" value="@tc.Id" />
                                                    <input type="hidden" name="DanhSachDiemSinhVien[0].DiemChiTiets[@tcIndex].DiemSo" value="0" />
                                                }
                                                <td>
                                                    <textarea class="nhanxet-input" 
                                                              name="DanhSachDiemSinhVien[0].DiemChiTiets[@tcIndex].NhanXet"
                                                              rows="@(Model.ChiNhanXet ? 3 : 2)"
                                                              placeholder="Nhận xét..." @(Model.ChiNhanXet ? "required" : "")>@tc.NhanXetDaCham</textarea>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    @if (!Model.ChiNhanXet)
                                    {
                                        <tfoot>
                                            <tr>
                                                <td colspan="4" style="text-align: right;"><strong>Tổng điểm:</strong></td>
                                                <td colspan="2">
                                                    <span class="tongDiem-sv-0" style="font-size: 18px; color: #0d6efd; font-weight: 700;">0.0</span>
                                                    <span style="color: #6b7280;"> / 10</span>
                                                </td>
                                            </tr>
                                        </tfoot>
                                    }
                                </table>
                            </div>
                        </div>
                    </div>
                }
            }

            <div class="form-footer" style="padding: 16px;">
                <a href="@Url.Action("Detail", new { id = Model.HoiDongId })" class="btn-action btn-secondary">
                    Hủy bỏ
                </a>
                <button type="submit" class="btn-action btn-primary">
                    <i class="fa-solid fa-save"></i> @(Model.ChiNhanXet ? "Lưu nhận xét" : "Lưu điểm")
                </button>
            </div>
        </form>
    </div>
</div>

