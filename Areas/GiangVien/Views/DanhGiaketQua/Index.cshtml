@{
    ViewData["Title"] = "Đánh giá kết quả đề tài";
}

<style>
    .content-body.dotdoan-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .dotdoan-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); display: flex; flex-direction: column;
        min-height: calc(100vh - 140px); font-family: inherit;
    }
    .page-header-row { margin-bottom: 15px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }

    .toolbar-row { display:flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; gap: 15px; flex-wrap: wrap; }
    .filter-wrapper { display:flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; background: transparent; padding: 0; }
    .filter-item { display: flex; flex-direction: column; gap: 4px; }
    .filter-label { font-weight: 500 !important; font-size: 13px !important; color: #333; display: block; margin-bottom: 4px; }
    .toolbar-input, .form-control { background: #fff !important; font-size: 13px !important; padding: 8px 12px !important; border: 1px solid #ced4da !important; border-radius: 4px !important; height: 36px !important; }
    .toolbar-input:focus, .form-control:focus { border-color: #484BE0 !important; box-shadow: 0 0 0 2px rgba(72, 75, 224, 0.1) !important; outline: none; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    .table-scroll { flex: 1; max-height: calc(100vh - 280px); overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px !important; color: #444; line-height: 1.4; white-space: nowrap; }
    tbody td { padding:12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; font-size: 13px !important; color: #333; }
    tbody tr:hover { background: #f9f9f9; }

    .toggle-btn { width: 30px; height: 30px; border-radius: 6px; border: 1px solid #e5e7eb; background: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: .15s ease; font-size: 13px; color: #111827; }
    .toggle-btn:hover { background: #f3f4f6; }
    .detail-row { background: #f9fafb; }
    .student-table { width: 100%; margin: 0; border: 1px solid #e5e7eb; border-radius: 8px; border-collapse: separate; border-spacing: 0; overflow: hidden; background: #fff; }
    .student-table thead th { background: #f8fafc; padding: 10px 12px; border-bottom: 1px solid #e5e7eb; white-space: nowrap; font-size: 12.5px !important; }
    .student-table tbody td { font-size: 12.5px !important; padding: 10px 12px; border-bottom: 1px solid #f1f5f9; color: #111827; }
    .student-table tbody tr:last-child td { border-bottom: none; }
    .student-table td[rowspan] { vertical-align: middle; text-align: center; font-weight: 600; color: #374151; }

    .edit-icon { width: 34px; height: 34px; border-radius: 8px; border: 1px solid #e5e7eb; background: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: .15s ease; }
    .edit-icon i { font-size: 14px; color: #111827; }
    .edit-icon:hover { background: #f3f4f6; }
    .edit-icon.is-red i { color: #e74c3c; }
    .plan-cell { vertical-align: middle; text-align: center; padding: 0; }
    .plan-center { display: flex; align-items: center; justify-content: center; height: 100%; min-height: 100%; text-align: center; }
</style>

<div class="content-body dotdoan-page">
    <div class="content-card">
        <div class="page-header-row">
            <h2 class="page-title">Đánh giá kết quả đề tài</h2>
        </div>

        <div class="toolbar-row">
            <div class="filter-wrapper">
                <div class="filter-item">
                    <span class="filter-label">Năm học</span>
                    <select class="form-control" style="width: 160px;">
                        <option value="">-- Tất cả --</option>
                        <option>2023-2024</option>
                        <option>2024-2025</option>
                        <option>2025-2026</option>
                    </select>
                </div>
                <div class="filter-item">
                    <span class="filter-label">Học kì</span>
                    <select class="form-control" style="width: 140px;">
                        <option value="">-- Tất cả --</option>
                        <option>101</option>
                        <option>102</option>
                        <option>103</option>
                    </select>
                </div>
            </div>

            <div style="display:flex; align-items:flex-end; gap:10px;">
                <div style="display:flex; flex-direction:column; gap:4px; align-items:flex-start;">
                    <span class="filter-label">Tìm kiếm</span>
                    <input type="text" class="toolbar-input" placeholder="Mã đề tài, Tên đề tài..." style="width: 250px;" />
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 50px;"></th>
                            <th>Mã đề tài</th>
                            <th>Tên đề tài</th>
                            <th>Ngành</th>
                            <th style="text-align:center;">Số lượng SV</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="parent-row">
                            <td><button class="toggle-btn" onclick="toggleRow(this)"><i class="fa-solid fa-plus"></i></button></td>
                            <td>DT01</td>
                            <td>Kiến trúc Học sâu lai cho phân đoạn khối u não trên ảnh MRI đa phương thức với Bộ dữ liệu BraTS</td>
                            <td>CNTT/CNPM</td>
                            <td style="text-align:center;">2</td>
                        </tr>
                        <tr class="detail-row" style="display:none;">
                            <td colspan="5">
                                <table class="student-table">
                                    <thead>
                                        <tr>
                                            <th>MSSV</th>
                                            <th>Họ và tên sinh viên</th>
                                            <th>Khóa</th>
                                            <th>Trạng thái</th>
                                            <th>Đánh giá và nhận xét</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>2174802010297</td>
                                            <td>Trương Quốc Duy</td>
                                            <td>K27</td>
                                            <td rowspan="2" class="plan-cell">
                                                <div class="plan-center">Chưa nhập điểm</div>
                                            </td>
                                            <td rowspan="2" class="plan-cell">
                                                <div class="plan-center">
                                                    <button class="edit-icon is-red" title="Chấm điểm / nhận xét">
                                                        <i class="fa-solid fa-pen-to-square"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>2174802010311</td>
                                            <td>Nguyễn Văn A</td>
                                            <td>K27</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    window.toggleRow = function(btn) {
        const tr = btn.closest('tr');
        const nextTr = tr.nextElementSibling;
        const icon = btn.querySelector('i');
        if (nextTr && nextTr.classList.contains('detail-row')) {
            if (nextTr.style.display === 'none') {
                nextTr.style.display = 'table-row';
                icon.classList.remove('fa-plus');
                icon.classList.add('fa-minus');
            } else {
                nextTr.style.display = 'none';
                icon.classList.remove('fa-minus');
                icon.classList.add('fa-plus');
            }
        }
    }
</script>
