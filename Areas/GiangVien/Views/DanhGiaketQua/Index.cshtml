@model DanhGiaKetQuaIndexViewModel
@{
    ViewData["Title"] = "Đánh giá kết quả đề tài";
    Layout = "~/Views/Shared/_Layout_GV.cshtml";
}

<style>
    :root { --primary: #484BE0; }
    .content-body.dg-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .dg-page .content-card { background: #fff; border-radius: 8px; padding: 20px; box-shadow: 0 0 10px rgba(0,0,0,0.05); display: flex; flex-direction: column; min-height: calc(100vh - 140px); }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0 0 15px; text-transform: uppercase; }
    .dot-info { background: #f0f4ff; border: 1px solid #dbeafe; border-radius: 8px; padding: 14px 18px; margin-bottom: 20px; font-size: 13px; color: #333; display: flex; align-items: center; gap: 10px; }
    .dot-info i { color: #2563eb; font-size: 16px; } .dot-info strong { color: #1e3a5f; }
    .toolbar-row { display: flex; justify-content: flex-end; margin-bottom: 20px; }
    .toolbar-input { background: #fff !important; font-size: 13px !important; padding: 8px 12px !important; border: 1px solid #ced4da !important; border-radius: 4px !important; height: 36px !important; width: 280px; }
    .toolbar-input:focus { border-color: var(--primary) !important; box-shadow: 0 0 0 2px rgba(72,75,224,0.1) !important; outline: none; }
    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    .table-scroll { flex: 1; max-height: calc(100vh - 300px); overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; color: #444; white-space: nowrap; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; color: #333; }
    tbody tr:hover { background: #f9f9f9; }
    .td-ellipsis { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .toggle-btn { width: 30px; height: 30px; border-radius: 6px; border: 1px solid #e5e7eb; background: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: .15s ease; font-size: 13px; color: #111827; }
    .toggle-btn:hover { background: #f3f4f6; border-color: var(--primary); color: var(--primary); }
    .detail-row { background: #f9fafb; }
    .detail-row > td { padding: 16px !important; }
    .student-table { width: 100%; border: 1px solid #e5e7eb; border-radius: 8px; border-collapse: separate; border-spacing: 0; overflow: hidden; background: #fff; }
    .student-table thead th { background: #f8fafc; padding: 10px 12px; border-bottom: 1px solid #e5e7eb; font-size: 12px !important; font-weight: 600; color: #374151; }
    .student-table tbody td { font-size: 12px !important; padding: 10px 12px; border-bottom: 1px solid #f1f5f9; }
    .student-table tbody tr:last-child td { border-bottom: none; }
    .status-badge { padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; display: inline-block; }
    .status-approved { background: #dcfce7; color: #166534; }
    .status-pending { background: #fef3c7; color: #92400e; }
    .status-no-report { background: #fee2e2; color: #991b1b; }
    .file-link { color: #2563eb; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; font-weight: 500; font-size: 12px; }
    .file-link:hover { text-decoration: underline; }
    .edit-icon { width: 34px; height: 34px; border-radius: 8px; border: 1px solid #e5e7eb; background: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: .15s ease; text-decoration: none; }
    .edit-icon i { font-size: 14px; color: #111827; }
    .edit-icon:hover { background: #f3f4f6; border-color: var(--primary); }
    .edit-icon:hover i { color: var(--primary); }
    .edit-icon.disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
    .plan-cell { vertical-align: middle; text-align: center; }
    .score-cell { font-weight: 600; color: #1e40af; }
    .no-score { color: #9ca3af; font-style: italic; }
    .empty-state { text-align: center; padding: 60px 20px; color: #6b7280; }
    .empty-state i { font-size: 48px; margin-bottom: 16px; color: #d1d5db; }
    .empty-state h4 { font-size: 16px; font-weight: 600; margin-bottom: 8px; color: #374151; }
    .empty-state p { font-size: 13px; }
    .alert-msg { padding: 12px 16px; border-radius: 8px; font-size: 13px; display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .alert-error { background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; }
    .alert-error i { font-size: 16px; }
</style>

<div class="content-body dg-page">
    <div class="content-card">
        <h2 class="page-title">Đánh giá kết quả đề tài</h2>

        @if (TempData["ErrorMessage"] is string errMsg)
        {
            <div class="alert-msg alert-error">
                <i class="fa-solid fa-exclamation-triangle"></i>
                <span>@errMsg</span>
            </div>
        }

        @if (Model.CoDot)
        {
            <div class="dot-info">
                <i class="fa-solid fa-calendar-check"></i> Đợt đồ án: <strong>@Model.TenDot</strong>
            </div>

            <div class="toolbar-row">
                <input type="text" id="txtSearch" class="toolbar-input" placeholder="Tìm mã đề tài, tên đề tài..." />
            </div>

            <div class="table-responsive">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th style="width:50px;"></th>
                                <th style="width:110px;">Mã đề tài</th>
                                <th>Tên đề tài</th>
                                <th style="width:140px;">Chuyên ngành</th>
                                <th style="width:120px; text-align:center;">Trạng thái</th>
                                <th style="width:100px; text-align:center;">Chấm điểm</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            @if (Model.DanhSachDeTai.Any())
                            {
                                foreach (var dt in Model.DanhSachDeTai)
                                {
                                    <tr class="parent-row" data-id="@dt.IdDeTai">
                                        <td>
                                            <button class="toggle-btn" onclick="toggleRow(this)"><i class="fa-solid fa-plus"></i></button>
                                        </td>
                                        <td><strong>@dt.MaDeTai</strong></td>
                                        <td class="td-ellipsis" title="@dt.TenDeTai">@dt.TenDeTai</td>
                                        <td>@dt.ChuyenNganh</td>
                                        <td style="text-align:center;">
                                            <span class="status-badge @dt.TrangThaiCss">@dt.TrangThaiText</span>
                                        </td>
                                        <td style="text-align:center;">
                                            @if (dt.TatCaSVCoBaoCaoDuyet)
                                            {
                                                <a href="@Url.Action("ChamDiemDeTai", new { id = dt.IdDeTai })" class="edit-icon" title="Chấm điểm theo tiêu chí">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="edit-icon disabled" title="Chưa đủ báo cáo cuối kỳ được duyệt">
                                                    <i class="fa-solid fa-lock"></i>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    <tr class="detail-row" style="display:none;" data-parent="@dt.IdDeTai">
                                        <td colspan="6">
                                            <table class="student-table">
                                                <thead>
                                                    <tr>
                                                        <th>MSSV</th>
                                                        <th>Họ tên</th>
                                                        <th>Khóa</th>
                                                        <th style="text-align:center; width:100px;">Điểm GVHD</th>
                                                        <th style="width:200px;">Báo cáo cuối kỳ</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var sv in dt.DanhSachSV)
                                                    {
                                                        <tr>
                                                            <td>@sv.Mssv</td>
                                                            <td><strong>@sv.HoTen</strong></td>
                                                            <td>@sv.KhoaHoc</td>
                                                            <td class="plan-cell">
                                                                @if (sv.DaChamDiem)
                                                                {
                                                                    <span class="score-cell">@sv.DiemGVHD?.ToString("F1")</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="no-score">Chưa chấm</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                @if (sv.CoBaoCaoCuoiKyDuyet && !string.IsNullOrEmpty(sv.FileBaoCaoCuoiKy))
                                                                {
                                                                    <a href="@sv.FileBaoCaoCuoiKy" target="_blank" class="file-link">
                                                                        <i class="fa-solid fa-file-pdf"></i> @(sv.TenFileBaoCao ?? "Xem file")
                                                                    </a>
                                                                }
                                                                else
                                                                {
                                                                    <span class="status-badge status-no-report"><i class="fa-solid fa-xmark"></i> Chưa có</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6">
                                        <div class="empty-state">
                                            <i class="fa-solid fa-folder-open"></i>
                                            <h4>Chưa có đề tài</h4>
                                            <p>Bạn chưa hướng dẫn đề tài nào được duyệt trong đợt này.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-calendar-xmark"></i>
                <h4>Chưa có đợt đồ án</h4>
                <p>Hiện tại chưa có đợt đồ án nào đang hoạt động.</p>
            </div>
        }
    </div>
</div>

<script>
    window.toggleRow = function (btn) {
        var tr = btn.closest('tr');
        var next = tr.nextElementSibling;
        var icon = btn.querySelector('i');
        if (next && next.classList.contains('detail-row')) {
            var show = next.style.display === 'none';
            next.style.display = show ? 'table-row' : 'none';
            icon.classList.toggle('fa-plus', !show);
            icon.classList.toggle('fa-minus', show);
        }
    };
    var searchInput = document.getElementById('txtSearch');
    if (searchInput) {
        var timeout;
        searchInput.addEventListener('input', function () {
            clearTimeout(timeout);
            timeout = setTimeout(function () {
                var kw = searchInput.value.toLowerCase();
                document.querySelectorAll('.parent-row').forEach(function (row) {
                    var match = row.textContent.toLowerCase().indexOf(kw) > -1;
                    row.style.display = match ? '' : 'none';
                    var detail = row.nextElementSibling;
                    if (detail && detail.classList.contains('detail-row')) {
                        detail.style.display = 'none';
                        var icon = row.querySelector('.toggle-btn i');
                        if (icon) { icon.classList.remove('fa-minus'); icon.classList.add('fa-plus'); }
                    }
                });
            }, 300);
        });
    }
</script>
