@model List<DATN_TMS.Areas.GiangVien.Models.BaoCaoNopGVDetailItem>

<table class="bc-table">
    <thead>
        <tr>
            <th style="width:50px;">STT</th>
            <th style="width:160px;">Sinh viên</th>
            <th style="width:150px;">Ngày nộp</th>
            <th>File báo cáo</th>
            <th style="width:220px;">Ghi chú</th>
            <th style="width:120px;">Trạng thái</th>
            <th style="width:100px; text-align:center;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @{
            var stt = 0;
        }
        @foreach (var item in Model)
        {
            stt++;
            <tr>
                <td>@stt</td>
                <td>
                    <div style="font-weight:600;">@item.TenSinhVien</div>
                    <div style="font-size:11px; color:#6b7280;">@item.Mssv</div>
                </td>
                <td>
                    <div style="font-size:12px;">@item.NgayNop</div>
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        <a href="@item.FilePath" target="_blank" class="file-link">
                            <i class="fa-solid fa-file-pdf"></i>
                            @(item.TenFile ?? "Xem file")
                        </a>
                    }
                    else
                    {
                        <span style="color:#9ca3af; font-style:italic;">Không có file</span>
                    }
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(item.GhiChuGui))
                    {
                        <div class="nhanxet-preview" title="@item.GhiChuGui">@item.GhiChuGui</div>
                    }
                    else
                    {
                        <span style="color:#9ca3af;">---</span>
                    }
                </td>
                <td>
                    <span class="status-badge @item.TrangThaiCss">@item.TrangThaiText</span>
                </td>
                <td style="text-align:center;">
                    @if (item.TrangThai == "CHO_DUYET")
                    {
                        <button type="button" class="action-btn btn-approve" title="Duyệt" onclick="openDuyetModal(@item.IdBaoCao, 'approve')">
                            <i class="fa-solid fa-check"></i>
                        </button>
                        <button type="button" class="action-btn btn-reject" title="Từ chối" onclick="openDuyetModal(@item.IdBaoCao, 'reject')">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="action-btn btn-view" title="Xem chi tiết" onclick="openDuyetModal(@item.IdBaoCao, 'view')">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
