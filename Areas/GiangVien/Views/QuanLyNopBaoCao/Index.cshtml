@model QuanLyNopBaoCaoIndexViewModel
@{
    ViewData["Title"] = "Quản lý nộp báo cáo";
    Layout = "~/Views/Shared/_Layout_GV.cshtml";
}

<style>
    .content-body.bc-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .bc-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); display: flex; flex-direction: column;
        min-height: calc(100vh - 140px); font-family: inherit;
    }

    .page-header-row { margin-bottom: 15px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }

    .dot-info {
        background: #f0f4ff; border: 1px solid #dbeafe; border-radius: 8px;
        padding: 14px 18px; margin-bottom: 20px; font-size: 13px; color: #333;
        display: flex; align-items: center; gap: 10px;
    }
    .dot-info i { color: #2563eb; font-size: 16px; }
    .dot-info strong { color: #1e3a5f; }

    .toolbar-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; gap: 15px; flex-wrap: wrap; }
    .filter-wrapper { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
    .filter-item { display: flex; flex-direction: column; gap: 4px; }
    .filter-label { font-weight: 500 !important; font-size: 13px !important; color: #333; display: block; margin-bottom: 4px; }
    .toolbar-input, .bc-page .form-control { background: #fff !important; font-size: 13px !important; padding: 8px 12px !important; border: 1px solid #ced4da !important; border-radius: 4px !important; height: 36px !important; }
    .toolbar-input:focus, .bc-page .form-control:focus { border-color: #484BE0 !important; box-shadow: 0 0 0 2px rgba(72, 75, 224, 0.1) !important; outline: none; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    .table-scroll { flex: 1; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px !important; color: #444; line-height: 1.4; white-space: nowrap; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; font-size: 13px !important; color: #333; }
    tbody tr:hover { background: #f9f9f9; }

    .td-ellipsis { max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .td-sv { max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #6b7280; font-size: 12px; }

    .status-badge { padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; display: inline-block; }
    .status-approved { background: #dcfce7; color: #166534; }
    .status-pending { background: #fef3c7; color: #92400e; }
    .status-rejected { background: #fee2e2; color: #991b1b; }
    .status-default { background: #f3f4f6; color: #6b7280; }

    .badge-count { display: inline-flex; align-items: center; justify-content: center; min-width: 24px; height: 22px; padding: 0 6px; border-radius: 10px; font-size: 11px; font-weight: 700; }
    .badge-decuong { background: #e0e7ff; color: #3730a3; }
    .badge-giuaky { background: #fef3c7; color: #92400e; }
    .badge-cuoiky { background: #d1fae5; color: #065f46; }
    .badge-pending { background: #fee2e2; color: #dc2626; }

    .action-btn { background: none; border: none; cursor: pointer; font-size: 15px; color: #484BE0; padding: 4px 6px; border-radius: 4px; transition: 0.15s; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .action-btn:hover { background: #eef2ff; color: #3538b2; }

    .text-center-empty { text-align: center; color: #6b7280; padding: 40px !important; }

    .empty-state { text-align: center; padding: 60px 20px; color: #6b7280; }
    .empty-state i { font-size: 48px; margin-bottom: 16px; color: #d1d5db; }
    .empty-state h4 { font-size: 16px; font-weight: 600; margin-bottom: 8px; color: #374151; }
    .empty-state p { font-size: 13px; }
</style>

<div class="content-body bc-page">
    <div class="content-card">
        <div class="page-header-row">
            <h2 class="page-title">Quản lý nộp báo cáo</h2>
        </div>

        @if (Model.CoDot)
        {
            <div class="dot-info">
                <i class="fa-solid fa-calendar-check"></i>
                Đợt đồ án: <strong>@Model.TenDot</strong>
                @if (!string.IsNullOrEmpty(Model.HocKi))
                {
                    <span style="margin-left: 10px;">| Học kỳ: <strong>@Model.HocKi</strong></span>
                }
            </div>

            <div class="toolbar-row">
                <div class="filter-wrapper">
                    <div class="filter-item">
                        <span class="filter-label">Trạng thái</span>
                        <select id="filterTrangThai" class="form-control" style="width: 180px;">
                            <option value="">-- Tất cả --</option>
                            <option value="pending">Có báo cáo chờ duyệt</option>
                            <option value="processed">Đã xử lý</option>
                            <option value="none">Chưa có báo cáo</option>
                        </select>
                    </div>
                </div>

                <div style="display:flex; align-items:flex-end; gap:10px;">
                    <div class="filter-item">
                        <span class="filter-label">Tìm kiếm</span>
                        <input type="text" id="txtSearch" class="toolbar-input" placeholder="Mã đề tài, tên đề tài, sinh viên..." style="width: 280px;" />
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th style="width:50px;">STT</th>
                                <th style="width:100px;">Mã đề tài</th>
                                <th>Tên đề tài</th>
                                <th style="width:120px;">Chuyên ngành</th>
                                <th style="width:180px;">Sinh viên</th>
                                <th style="width:80px; text-align:center;">Đề cương</th>
                                <th style="width:80px; text-align:center;">Giữa kỳ</th>
                                <th style="width:80px; text-align:center;">Cuối kỳ</th>
                                <th style="width:140px;">Trạng thái</th>
                                <th style="width:70px; text-align:center;">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DanhSachDeTai != null && Model.DanhSachDeTai.Any())
                            {
                                var stt = 0;
                                foreach (var item in Model.DanhSachDeTai)
                                {
                                    stt++;
                                    var filterStatus = item.TongBaoCaoChoDuyet > 0 ? "pending" :
                                                       (item.SoBaoCaoDeCuong + item.SoBaoCaoGiuaKy + item.SoBaoCaoCuoiKy) > 0 ? "processed" : "none";
                                    <tr data-status="@filterStatus">
                                        <td>@stt</td>
                                        <td><strong>@item.MaDeTai</strong></td>
                                        <td class="td-ellipsis" title="@item.TenDeTai">@item.TenDeTai</td>
                                        <td>@item.TenChuyenNganh</td>
                                        <td class="td-sv" title="@item.DanhSachSinhVien">
                                            <i class="fa-solid fa-users" style="margin-right:4px; color:#9ca3af;"></i>
                                            @item.DanhSachSinhVien
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="badge-count badge-decuong">@item.SoBaoCaoDeCuong</span>
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="badge-count badge-giuaky">@item.SoBaoCaoGiuaKy</span>
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="badge-count badge-cuoiky">@item.SoBaoCaoCuoiKy</span>
                                        </td>
                                        <td>
                                            @if (item.TongBaoCaoChoDuyet > 0)
                                            {
                                                <span class="status-badge status-pending">
                                                    <i class="fa-solid fa-clock" style="margin-right:4px;"></i>@item.TongBaoCaoChoDuyet chờ duyệt
                                                </span>
                                            }
                                            else if ((item.SoBaoCaoDeCuong + item.SoBaoCaoGiuaKy + item.SoBaoCaoCuoiKy) > 0)
                                            {
                                                <span class="status-badge status-approved">
                                                    <i class="fa-solid fa-check" style="margin-right:4px;"></i>Đã xử lý
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-default">Chưa có báo cáo</span>
                                            }
                                        </td>
                                        <td style="text-align:center;">
                                            <a href="@Url.Action("Detail", new { id = item.IdDeTai })" class="action-btn" title="Xem chi tiết">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="text-center-empty">
                                        <div class="empty-state">
                                            <i class="fa-solid fa-folder-open"></i>
                                            <h4>Chưa có đề tài nào</h4>
                                            <p>Bạn chưa hướng dẫn đề tài nào trong đợt đồ án này.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-calendar-xmark"></i>
                <h4>Chưa có đợt đồ án</h4>
                <p>Hiện tại chưa có đợt đồ án nào đang hoạt động.</p>
            </div>
        }
    </div>
</div>

<script>
    // ===== FILTER & SEARCH =====
    var searchTimeout = null;
    var searchInput = document.getElementById('txtSearch');
    var filterTrangThai = document.getElementById('filterTrangThai');

    function filterTable() {
        if (!searchInput || !filterTrangThai) return;

        var keyword = searchInput.value.toLowerCase();
        var status = filterTrangThai.value;

        document.querySelectorAll('tbody tr[data-status]').forEach(function(row) {
            var matchText = row.textContent.toLowerCase().indexOf(keyword) > -1;
            var matchStatus = !status || row.getAttribute('data-status') === status;
            row.style.display = (matchText && matchStatus) ? '' : 'none';
        });
    }

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(filterTable, 400);
        });
    }

    if (filterTrangThai) {
        filterTrangThai.addEventListener('change', filterTable);
    }
</script>