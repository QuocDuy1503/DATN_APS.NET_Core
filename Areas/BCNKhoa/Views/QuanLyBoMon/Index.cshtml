@using X.PagedList.Mvc.Core;
@using X.PagedList;
@model IPagedList<DATN_TMS.Areas.BCNKhoa.Models.BoMonViewModel>

@{
    ViewData["Title"] = "Quản lý Bộ Môn";
}

<style>
    .dotdoan-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }

    .dotdoan-page .content-card {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 140px);
        font-family: inherit;
    }

    .page-header-row { margin-bottom: 15px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }

    .toolbar-row { display:flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; gap: 15px; flex-wrap: wrap; }
    .filter-wrapper { display:flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; background: transparent; padding: 0; }
    .filter-item { display: flex; flex-direction: column; gap: 4px; }
    .filter-label { font-weight: 500 !important; font-size: 13px !important; color: #333; display: block; margin-bottom: 4px; }
    .toolbar-input, .form-control { background: #fff !important; font-size: 13px !important; padding: 8px 12px !important; border: 1px solid #ced4da !important; border-radius: 4px !important; height: 36px !important; }
    .toolbar-input:focus, .form-control:focus { border-color: #484BE0 !important; box-shadow: 0 0 0 2px rgba(72, 75, 224, 0.1) !important; outline: none; }

    .btn-primary { background-color: #0d6efd; border-color: #0d6efd; }
    .btn-primary:hover { background-color: #0b5ed7; border-color: #0b5ed7; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px !important; color: #444; line-height: 1.4; }
    tbody td { padding: 12px 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; font-size: 13px !important; color: #333; }
    tbody tr:hover { background: #f9f9f9; }

    .pagination-container { display: flex; justify-content: center; margin-top: 12px; margin-top: auto; padding-top: 8px; }
    .pagination { display: inline-flex; gap: 8px; padding: 0; margin: 0; list-style: none; }
    .pagination li a, .pagination li span { min-width: 42px; height: 38px; border-radius: 6px; border: 1px solid #d1d5db; background: #fff; color: #374151; display: inline-flex; align-items: center; justify-content: center; padding: 0 12px; text-decoration: none; font-weight: 600; transition: all 0.15s ease; }
    .pagination li a:hover { border-color: #2563eb; color: #2563eb; }
    .pagination li.active span { background: #0d6efd; border-color: #0d6efd; color: #fff; box-shadow: 0 6px 18px rgba(13,110,253,0.25); }
    .pagination li.disabled span, .pagination li.disabled a { color: #9ca3af; border-color: #e5e7eb; cursor: default; box-shadow: none; }
</style>

<div class="content-body dotdoan-page">
    <div class="content-card">
        <div class="page-header-row">
            <h2 class="page-title">Quản lý Bộ Môn</h2>
        </div>

        <div class="toolbar-row">
            <div class="filter-wrapper"></div>

            <div class="toolbar-right" style="display:flex; align-items:flex-end; gap:10px;">
                <div class="search-box" style="display:flex; flex-direction:column; gap:4px; align-items:flex-start;">
                    <span class="filter-label">Tìm kiếm:</span>
                    <input type="text" id="searchInput" name="searchString" 
                           value="@ViewBag.CurrentFilter" 
                           class="toolbar-input search-input" 
                           placeholder="Nhập mã hoặc tên bộ môn..." 
                           style="width: 280px;">
                </div>
                
                <button type="button" class="btn btn-primary" id="btnOpenModal">
                    <i class="fa-solid fa-plus"></i> Thêm bộ môn mới
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width: 120px;">Mã bộ môn</th>
                        <th>Tên bộ môn</th>
                        <th>Người tạo</th>
                        <th style="width: 110px;">Ngày tạo</th>
                        <th>Người sửa</th>
                        <th style="width: 110px;">Ngày sửa</th>
                        <th class="text-center" style="width: 100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span>@item.TenVietTat</span></td>
                                <td><span>@item.TenBoMon</span></td>
                                <td>@item.NguoiTao</td>
                                <td>@(item.NgayTao.HasValue ? item.NgayTao.Value.ToString("dd/MM/yyyy") : "-")</td>
                                <td>@item.NguoiSua</td>
                                <td>@(item.NgaySua.HasValue ? item.NgaySua.Value.ToString("dd/MM/yyyy") : "-")</td>

                                <td class="text-center">
                                    <button class="action-btn btn-edit-icon btn-edit" 
                                            data-id="@item.Id" 
                                            title="Sửa">
                                        <i class="fa-regular fa-pen-to-square"></i>
                                    </button>
                                    
                                    <button class="action-btn btn-delete-icon btn-delete-confirm" 
                                            data-id="@item.Id" 
                                            data-name="@item.TenBoMon" 
                                            title="Xóa">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted p-4">Không tìm thấy dữ liệu bộ môn nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Partial: Modal Thêm mới -->
        <partial name="_CreateModal" />

        <!-- Partial: Modal Sửa -->
        <partial name="_EditModal" />

        <div class="pagination-container">
             @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchString = ViewBag.CurrentFilter }),
            new PagedListRenderOptions {
                LiElementClasses = new string[] { "page-item" },
                PageClasses = new string[] { "page-link" },
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                LinkToPreviousPageFormat = "«",
                LinkToNextPageFormat = "»",
                EllipsesFormat = "...",
                MaximumPageNumbersToDisplay = 5
            })
        </div>
    </div>

    <!-- Form ẩn cho Delete -->
    <form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteId" />
    </form>
</div>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    // --- TempData Messages ---
    var successMsg = '@Html.Raw(TempData["SuccessMessage"])';
    var errorMsg = '@Html.Raw(TempData["ErrorMessage"])';

    if (successMsg && successMsg.length > 0) {
        Swal.fire({
            icon: 'success',
            title: 'Thành công!',
            text: successMsg,
            confirmButtonText: 'Đóng',
            confirmButtonColor: '#484BE0',
            timer: 3000
        });
    }

    if (errorMsg && errorMsg.length > 0) {
        Swal.fire({
            icon: 'error',
            title: 'Có lỗi xảy ra',
            text: errorMsg,
            confirmButtonText: 'Kiểm tra lại',
            confirmButtonColor: '#d33'
        });
    }

    // --- Delete Confirm ---
    function handleDeleteClick() {
        const id = this.getAttribute('data-id');
        const name = this.getAttribute('data-name');

        Swal.fire({
            title: 'Xác nhận xóa?',
            html: `Bạn có chắc chắn muốn xóa bộ môn <strong>"${name}"</strong>?<br>Hành động này không thể hoàn tác!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Vâng, xóa nó!',
            cancelButtonText: 'Hủy bỏ'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        });
    }

    // --- Bind delete events ---
    window.rebindDeleteEvents = function() {
        const deleteBtns = document.querySelectorAll('.btn-delete-confirm');
        deleteBtns.forEach(btn => {
            btn.removeEventListener('click', handleDeleteClick);
            btn.addEventListener('click', handleDeleteClick);
        });
    };
    rebindDeleteEvents();

    // --- Bind edit events ---
    window.rebindEditEvents = function() {
        const editBtns = document.querySelectorAll('.btn-edit');
        editBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                openEditModal(id);
            });
        });
    };
    rebindEditEvents();

    // --- Search Real-time ---
    const searchInput = document.getElementById('searchInput');
    const tableContainer = document.querySelector('.table-responsive');
    const paginationContainer = document.querySelector('.pagination-container');
    let timeout = null;

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(timeout);
            timeout = setTimeout(performSearch, 500);
        });
    }

    function performSearch() {
        const keyword = searchInput.value;
        const url = `@Url.Action("Index")?searchString=${encodeURIComponent(keyword)}`;

        fetch(url)
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                if (tableContainer) tableContainer.innerHTML = doc.querySelector('.table-responsive').innerHTML;
                if (paginationContainer) paginationContainer.innerHTML = doc.querySelector('.pagination-container').innerHTML;
                rebindDeleteEvents();
                rebindEditEvents();
            })
            .catch(err => console.error('Lỗi tìm kiếm:', err));
    }
});
</script>
