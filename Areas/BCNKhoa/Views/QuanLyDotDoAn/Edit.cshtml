                                   placeholder="dd/MM/yyyy">
                            <input type="hidden" name="NgayBatDauDuyetDeXuatDeTai" value="@(Model.NgayBatDauDuyetDeXuatDeTai.HasValue ? Model.NgayBatDauDuyetDeXuatDeTai.Value.ToString("yyyy-MM-dd") : "")">
                        </td>
                        <td>
