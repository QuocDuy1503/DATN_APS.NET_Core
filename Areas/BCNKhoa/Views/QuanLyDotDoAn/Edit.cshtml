                                   value="@(Model.NgayBatDauBaoCaoCuoiKi.HasValue ? Model.NgayBatDauBaoCaoCuoiKi.Value.ToString("dd/MM/yyyy") : "")"
                                   placeholder="dd/MM/yyyy">
                            <input type="hidden" name="NgayBatDauBaoCaoCuoiKi" value="@(Model.NgayBatDauBaoCaoCuoiKi.HasValue ? Model.NgayBatDauBaoCaoCuoiKi.Value.ToString("yyyy-MM-dd") : "")">
