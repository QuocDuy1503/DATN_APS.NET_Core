                                   placeholder="dd/MM/yyyy">
                            <input type="hidden" name="NgayKetThucBaoCaoGiuaKi" value="@(Model.NgayKetThucBaoCaoGiuaKi.HasValue ? Model.NgayKetThucBaoCaoGiuaKi.Value.ToString("yyyy-MM-dd") : "")">
