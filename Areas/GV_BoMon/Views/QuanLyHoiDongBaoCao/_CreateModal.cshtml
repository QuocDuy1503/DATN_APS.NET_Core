@* Modal thêm hội đồng báo cáo cho Bộ môn *@
<style>
    .modal-overlay {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .modal-overlay.show { display: flex; opacity: 1; }

    .modal-dialog {
        background-color: white;
        width: 100%;
        max-width: 550px;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        overflow: hidden;
        transform: translateY(-20px);
        transition: transform 0.3s ease;
    }
    .modal-overlay.show .modal-dialog { transform: translateY(0); }

    .modal-header {
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #f0f0f0;
    }
    .modal-title { font-weight: 700; font-size: 18px; color: #333; }
    .btn-close-custom {
        background: transparent;
        border: 1px solid #ddd;
        border-radius: 4px;
        color: #999;
        font-size: 20px;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }
    .btn-close-custom:hover { background-color: #f5f5f5; color: #333; }

    .modal-body { padding: 20px; }
    .form-group { margin-bottom: 15px; }
    .form-group label { font-weight: 600; font-size: 13px; margin-bottom: 8px; display: block; color: #555; }
    .form-group label .required { color: #dc3545; }
    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        font-size: 13px;
        box-sizing: border-box;
    }
    .form-control:focus { border-color: #484BE0; outline: none; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }

    .modal-footer {
        padding: 15px 20px;
        border-top: 1px solid #f0f0f0;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }
    .btn-secondary {
        background-color: #fff;
        color: #333;
        border: 1px solid #ddd;
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        cursor: pointer;
        font-size: 13px;
    }
    .btn-secondary:hover { background-color: #f9f9f9; }
    .btn-save {
        background-color: #484BE0;
        color: white;
        border: none;
        padding: 8px 25px;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        font-size: 13px;
    }
    .btn-save:hover { background-color: #3a3dc7; }

    .phase-info {
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        padding: 12px 14px;
        margin-bottom: 15px;
        font-size: 12px;
        color: #1e40af;
        display: none;
    }
    .phase-info i { margin-right: 6px; }
    .phase-info.show { display: block; }
    .phase-info.error { background: #fef2f2; border-color: #fecaca; color: #dc2626; }
</style>

<div class="modal-overlay" id="addModal">
    <div class="modal-dialog">
        <div class="modal-header">
            <div class="modal-title">Thêm hội đồng báo cáo mới</div>
            <button type="button" class="btn-close-custom close-modal">&times;</button>
        </div>

        <form asp-action="Create" method="post" id="formCreateHD">
            @Html.AntiForgeryToken()
            <div class="modal-body">
                <div class="form-group">
                    <label>Tên hội đồng <span class="required">*</span></label>
                    <input type="text" name="TenHoiDong" class="form-control" placeholder="VD: Hội đồng bảo vệ đồ án" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Loại hội đồng <span class="required">*</span></label>
                        <select name="LoaiHoiDong" id="selectLoaiHoiDong" class="form-control" required>
                            <option value="">-- Chọn loại --</option>
                            <option value="GIUA_KY">Giữa kì</option>
                            <option value="CUOI_KY">Cuối kì</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Bộ môn</label>
                        <select name="IdBoMon" class="form-control">
                            <option value="">-- Chọn bộ môn --</option>
                            @if (ViewBag.ListBoMon != null)
                            {
                                foreach (SelectListItem item in ViewBag.ListBoMon)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Thông tin giai đoạn -->
                <div class="phase-info" id="phaseInfo">
                    <i class="fa-solid fa-circle-info"></i>
                    <span id="phaseInfoText"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Ngày báo cáo</label>
                        <input type="date" name="NgayBaoCao" id="inputNgayBaoCao" class="form-control">
                    </div>
                    <div class="form-group">
                        <label>Giờ bắt đầu</label>
                        <input type="time" name="GioBatDau" class="form-control">
                    </div>
                </div>

                <div class="form-group">
                    <label>Địa điểm</label>
                    <input type="text" name="DiaDiem" class="form-control" placeholder="VD: Phòng A101">
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary close-modal">Hủy</button>
                <button type="submit" class="btn btn-save" id="btnSubmitCreate">Lưu</button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    var modal = document.getElementById('addModal');
    var btnOpen = document.getElementById('btnOpenModal');
    var btnCloses = document.querySelectorAll('#addModal .close-modal');
    var selectLoai = document.getElementById('selectLoaiHoiDong');
    var phaseInfo = document.getElementById('phaseInfo');
    var phaseInfoText = document.getElementById('phaseInfoText');
    var inputNgayBaoCao = document.getElementById('inputNgayBaoCao');
    var btnSubmit = document.getElementById('btnSubmitCreate');
    var formCreate = document.getElementById('formCreateHD');

    var canSubmit = false;

    btnOpen?.addEventListener('click', function (e) {
        e.preventDefault();
        modal.classList.add('show');
        // Reset form
        formCreate.reset();
        phaseInfo.classList.remove('show', 'error');
        canSubmit = false;
    });

    btnCloses.forEach(btn => btn.addEventListener('click', () => modal.classList.remove('show')));
    window.addEventListener('click', e => { if (e.target == modal) modal.classList.remove('show'); });

    // Kiểm tra giai đoạn khi chọn loại hội đồng
    selectLoai?.addEventListener('change', function() {
        var loai = this.value;
        if (!loai) {
            phaseInfo.classList.remove('show', 'error');
            canSubmit = false;
            return;
        }

        // Gọi API kiểm tra giai đoạn
        fetch('@Url.Action("CheckGiaiDoanBaoCao", "QuanLyHoiDongBaoCao", new { area = "GV_BoMon" })' + '?loaiHoiDong=' + loai)
            .then(res => res.json())
            .then(data => {
                phaseInfo.classList.add('show');
                if (data.allowed) {
                    phaseInfo.classList.remove('error');
                    phaseInfoText.innerHTML = '<i class="fa-solid fa-check-circle"></i> ' + (loai === 'GIUA_KY' ? 'Đang trong giai đoạn lập hội đồng báo cáo giữa kì.' : 'Đang trong giai đoạn lập hội đồng báo cáo cuối kì.');
                    canSubmit = true;

                    // Set min/max cho ngày báo cáo
                    if (data.ngayBatDau && data.ngayKetThuc) {
                        inputNgayBaoCao.min = data.ngayBatDau;
                        inputNgayBaoCao.max = data.ngayKetThuc;
                    }
                } else {
                    phaseInfo.classList.add('error');
                    phaseInfoText.innerHTML = '<i class="fa-solid fa-exclamation-triangle"></i> ' + data.message;
                    canSubmit = false;
                }
            })
            .catch(() => {
                phaseInfo.classList.add('show', 'error');
                phaseInfoText.textContent = 'Không thể kiểm tra giai đoạn. Vui lòng thử lại.';
                canSubmit = false;
            });
    });

    // Validate trước khi submit
    formCreate?.addEventListener('submit', function(e) {
        if (!canSubmit) {
            e.preventDefault();
            alert('Không thể tạo hội đồng vì chưa đến giai đoạn lập hội đồng hoặc đã hết hạn.');
            return false;
        }
    });
});
</script>
