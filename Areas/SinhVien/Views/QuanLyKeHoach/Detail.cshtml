@model DATN_TMS.Models.KeHoachCongViec
@{
    ViewData["Title"] = "Chi tiết kế hoạch";
    Layout = "~/Views/Shared/_Layout_SV.cshtml";

    var statusText = Model.TrangThai switch
    {
        "DA_HOAN_THANH" => "Đã hoàn thành",
        "DANG_THUC_HIEN" => "Đang thực hiện",
        "CHO_DUYET" => "Chờ duyệt",
        "CHUA_THUC_HIEN" => "Chưa thực hiện",
        _ => Model.TrangThai ?? "---"
    };
    var statusClass = Model.TrangThai switch
    {
        "DA_HOAN_THANH" => "status-completed",
        "DANG_THUC_HIEN" => "status-running",
        "CHO_DUYET" => "status-waiting",
        _ => "status-pending"
    };
}

<style>
    .content-body.dotdoan-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .dotdoan-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05);
        min-height: calc(100vh - 140px); font-family: inherit;
    }

    .form-header {
        display: flex; align-items: center; gap: 15px;
        margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #eee;
    }
    .btn-back-circle {
        display: flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; background-color: #f3f4f6; color: #555;
        border-radius: 50%; text-decoration: none; transition: 0.2s; font-size: 14px;
    }
    .btn-back-circle:hover { background-color: #e5e7eb; color: #2563eb; transform: translateX(-2px); }
    .form-title { font-size: 18px; font-weight: 700; color: #1f2937; margin: 0; }

    .detail-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    .detail-item { margin-bottom: 0; }
    .detail-item.full-width { grid-column: 1 / -1; }
    .detail-label {
        display: block; font-weight: 600; color: #444; margin-bottom: 6px; font-size: 13px;
    }
    .detail-value {
        width: 100%; padding: 10px 14px; border: 1px solid #d1d5db; border-radius: 6px;
        background-color: #f9fafb; color: #333; font-size: 13px; min-height: 38px;
        display: flex; align-items: center;
    }
    .detail-value.multiline {
        min-height: 70px; align-items: flex-start; white-space: pre-wrap;
    }

    .status-badge { padding: 6px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; color: #fff; background: #6b7280; }
    .status-completed { background: #16a34a; }
    .status-running { background: #2563eb; }
    .status-waiting { background: #f59e0b; }
    .status-pending { background: #6b7280; }

    .meta-card {
        background: #f0f4ff; border: 1px solid #dbeafe; border-radius: 8px;
        padding: 14px 18px; margin-bottom: 24px;
        display: flex; gap: 24px; align-items: center; flex-wrap: wrap; font-size: 13px; color: #333;
    }
    .meta-card strong { color: #1e3a5f; }

    .file-link { color: #2563eb; text-decoration: none; font-weight: 500; }
    .file-link:hover { text-decoration: underline; }

    .btn-row { margin-top: 24px; display: flex; justify-content: flex-start; }
    .btn-secondary {
        padding: 8px 18px; border-radius: 6px; font-size: 13px; font-weight: 600;
        cursor: pointer; border: 1px solid #d1d5db; background: #f3f4f6; color: #333;
        text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: 0.15s;
    }
    .btn-secondary:hover { background: #e5e7eb; }
</style>

<div class="content-body dotdoan-page">
    <div class="content-card">
        <div class="form-header">
            <a asp-action="Index" class="btn-back-circle" title="Quay lại danh sách">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h3 class="form-title">Chi tiết kế hoạch công việc</h3>
        </div>

        <div class="meta-card">
            <div><strong>Đợt:</strong> @(Model.IdDotNavigation?.TenDot ?? "---")</div>
            <div>
                <strong>Trạng thái:</strong>
                <span class="status-badge @statusClass">@statusText</span>
            </div>
        </div>

        <div class="detail-grid">
            <div class="detail-item full-width">
                <span class="detail-label">Tên công việc</span>
                <div class="detail-value">@(Model.TenCongViec ?? "---")</div>
            </div>

            <div class="detail-item">
                <span class="detail-label">Ngày bắt đầu (dự kiến)</span>
                <div class="detail-value">@(Model.NgayBatDau.HasValue ? Model.NgayBatDau.Value.ToString("dd/MM/yyyy") : "---")</div>
            </div>

            <div class="detail-item">
                <span class="detail-label">Ngày kết thúc (dự kiến)</span>
                <div class="detail-value">@(Model.NgayKetThuc.HasValue ? Model.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "---")</div>
            </div>

            <div class="detail-item">
                <span class="detail-label">Ngày bắt đầu thực tế</span>
                <div class="detail-value">@(Model.NgayBatDauThucTe.HasValue ? Model.NgayBatDauThucTe.Value.ToString("dd/MM/yyyy") : "---")</div>
            </div>

            <div class="detail-item">
                <span class="detail-label">Ngày kết thúc thực tế</span>
                <div class="detail-value">@(Model.NgayKetThucThucTe.HasValue ? Model.NgayKetThucThucTe.Value.ToString("dd/MM/yyyy") : "---")</div>
            </div>

            <div class="detail-item full-width">
                <span class="detail-label">Mô tả công việc</span>
                <div class="detail-value multiline">@(Model.MoTaCongViec ?? "---")</div>
            </div>

            <div class="detail-item full-width">
                <span class="detail-label">Ghi chú</span>
                <div class="detail-value multiline">@(Model.GhiChu ?? "---")</div>
            </div>

            <div class="detail-item full-width">
                <span class="detail-label">File minh chứng</span>
                <div class="detail-value">
                    @if (Model.IdFileMinhChungNavigation != null && !string.IsNullOrEmpty(Model.IdFileMinhChungNavigation.FileBaocao))
                    {
                        <a href="@Model.IdFileMinhChungNavigation.FileBaocao" class="file-link" target="_blank">
                            <i class="fa-solid fa-paperclip"></i> @Model.IdFileMinhChungNavigation.TenBaoCao
                        </a>
                    }
                    else
                    {
                        <span>Không có file</span>
                    }
                </div>
            </div>
        </div>

        <div class="btn-row">
            <a asp-action="Index" class="btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>
