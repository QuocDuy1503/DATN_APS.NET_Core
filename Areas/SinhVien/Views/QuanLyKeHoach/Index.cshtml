@model IEnumerable<DATN_TMS.Models.KeHoachCongViec>
@{
    ViewData["Title"] = "Bảng kế hoạch";
    Layout = "~/Views/Shared/_Layout_SV.cshtml";
}

<style>
    .content-body.dotdoan-page { font-family: 'Segoe UI', Tahoma, sans-serif !important; }
    .dotdoan-page .content-card {
        background: #fff; border-radius: 8px; padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05); display: flex; flex-direction: column;
        min-height: calc(100vh - 140px); font-family: inherit;
    }

    .page-header-row { margin-bottom: 15px; }
    .page-title { font-size: 20px; font-weight: 700; color: #2c3e50; margin: 0; text-transform: uppercase; }

    .toolbar-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; gap: 15px; flex-wrap: wrap; }
    .filter-wrapper { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; background: transparent; padding: 0; }
    .filter-item { display: flex; flex-direction: column; gap: 4px; }
    .filter-label { font-weight: 500 !important; font-size: 13px !important; color: #333; display: block; margin-bottom: 4px; }
    .toolbar-input, .form-control { background: #fff !important; font-size: 13px !important; padding: 8px 12px !important; border: 1px solid #ced4da !important; border-radius: 4px !important; height: 36px !important; }
    .toolbar-input:focus, .form-control:focus { border-color: #484BE0 !important; box-shadow: 0 0 0 2px rgba(72, 75, 224, 0.1) !important; outline: none; }

    .table-responsive { border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; background: #fff; flex: 1; display: flex; flex-direction: column; }
    .table-scroll { flex: 1; max-height: calc(100vh - 280px); overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px !important; table-layout: fixed; }
    thead th { position: sticky; top: 0; background: #f3f4f6; z-index: 2; font-weight: 700 !important; padding: 12px 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px !important; color: #444; line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    tbody td { padding: 12px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; font-size: 13px !important; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    tbody tr:hover { background: #f9f9f9; }

    .status-badge { padding: 6px 10px; border-radius: 10px; font-size: 12px; font-weight: 600; color: #fff; background: #6b7280; }
    .status-completed { background: #16a34a; }
    .status-running { background: #2563eb; }
    .status-waiting { background: #f59e0b; }
    .status-pending { background: #6b7280; }

    .action-btn { background: none; border: none; cursor: pointer; font-size: 15px; color: #2980b9; padding: 4px 6px; border-radius: 4px; transition: 0.15s; text-decoration: none; }
    .action-btn:hover { background: #eef2ff; color: #1d4ed8; }

    .text-center-empty { text-align: center; color: #6b7280; padding: 40px !important; }
</style>

<div class="content-body dotdoan-page">
    <div class="content-card">
        <div class="page-header-row">
            <h2 class="page-title">Bảng kế hoạch</h2>
        </div>

        <div class="toolbar-row">
            <div class="filter-wrapper">
                <div class="filter-item">
                    <span class="filter-label">Trạng thái</span>
                    <select id="filterStatus" class="form-control" style="width: 160px;">
                        <option value="">-- Tất cả --</option>
                        <option value="CHUA_THUC_HIEN">Chưa thực hiện</option>
                        <option value="DANG_THUC_HIEN">Đang thực hiện</option>
                        <option value="DA_HOAN_THANH">Đã hoàn thành</option>
                        <option value="CHO_DUYET">Chờ duyệt</option>
                    </select>
                </div>
            </div>

            <div style="display:flex; align-items:flex-end; gap:10px;">
                <div style="display:flex; flex-direction:column; gap:4px; align-items:flex-start;">
                    <span class="filter-label">Tìm kiếm</span>
                    <input type="text" id="txtSearch" class="toolbar-input" placeholder="Tên công việc..." style="width: 240px;" />
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th style="width:50px;">STT</th>
                            <th>Tên công việc</th>
                            <th style="text-align:center;">Ngày bắt đầu</th>
                            <th style="text-align:center;">Ngày kết thúc</th>
                            <th style="text-align:center;">Ngày BĐ thực tế</th>
                            <th style="text-align:center;">Ngày KT thực tế</th>
                            <th style="text-align:center; width:130px;">Trạng thái</th>
                            <th style="text-align:center; width:80px;">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var stt = 0;
                            foreach (var item in Model)
                            {
                                stt++;
                                var statusClass = item.TrangThai switch
                                {
                                    "DA_HOAN_THANH" => "status-completed",
                                    "DANG_THUC_HIEN" => "status-running",
                                    "CHO_DUYET" => "status-waiting",
                                    _ => "status-pending"
                                };
                                var statusText = item.TrangThai switch
                                {
                                    "DA_HOAN_THANH" => "Đã hoàn thành",
                                    "DANG_THUC_HIEN" => "Đang thực hiện",
                                    "CHO_DUYET" => "Chờ duyệt",
                                    "CHUA_THUC_HIEN" => "Chưa thực hiện",
                                    _ => item.TrangThai ?? "---"
                                };
                                <tr data-status="@item.TrangThai">
                                    <td>@stt</td>
                                    <td title="@item.TenCongViec">@item.TenCongViec</td>
                                    <td style="text-align:center;">@(item.NgayBatDau.HasValue ? item.NgayBatDau.Value.ToString("dd/MM/yyyy") : "---")</td>
                                    <td style="text-align:center;">@(item.NgayKetThuc.HasValue ? item.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "---")</td>
                                    <td style="text-align:center;">@(item.NgayBatDauThucTe.HasValue ? item.NgayBatDauThucTe.Value.ToString("dd/MM/yyyy") : "---")</td>
                                    <td style="text-align:center;">@(item.NgayKetThucThucTe.HasValue ? item.NgayKetThucThucTe.Value.ToString("dd/MM/yyyy") : "---")</td>
                                    <td style="text-align:center;">
                                        <span class="status-badge @statusClass">@statusText</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <a asp-action="Detail" asp-route-id="@item.Id" class="action-btn" title="Xem chi tiết">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center-empty">Chưa có kế hoạch công việc nào</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    var searchTimeout = null;
    var searchInput = document.getElementById('txtSearch');
    var filterStatus = document.getElementById('filterStatus');

    function filterTable() {
        var keyword = searchInput.value.toLowerCase();
        var status = filterStatus.value;
        document.querySelectorAll('tbody tr').forEach(function (row) {
            var matchText = row.textContent.toLowerCase().indexOf(keyword) > -1;
            var matchStatus = !status || row.getAttribute('data-status') === status;
            row.style.display = (matchText && matchStatus) ? '' : 'none';
        });
    }

    searchInput.addEventListener('input', function () {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(filterTable, 500);
    });

    filterStatus.addEventListener('change', filterTable);
</script>
