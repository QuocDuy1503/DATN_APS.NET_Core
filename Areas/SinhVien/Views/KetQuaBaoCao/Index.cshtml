@model KetQuaBaoCaoViewModel
@{
    ViewData["Title"] = "Kết quả báo cáo hội đồng";
}

<style>
    :root { --primary: #484BE0; }

    .content-card {
        background-color: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05);
    }

    .page-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        margin: 0 0 20px 0;
        text-transform: uppercase;
    }

    /* Dot info - thống nhất với NopBaoCao */
    .dot-info {
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        padding: 14px 18px;
        margin-bottom: 20px;
        display: flex;
        gap: 20px;
        align-items: center;
        flex-wrap: wrap;
        font-size: 13px;
        color: #333;
    }

    .dot-info strong { color: #1e3a5f; }
    .dot-info i { color: var(--primary); }

    /* Alert boxes */
    .alert-box {
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
    .alert-warning { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }
    .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }

    .section {
        margin-bottom: 24px;
    }

    .section-title {
        font-size: 15px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--primary);
        display: inline-block;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    .field {
        display: flex;
        flex-direction: column;
    }

    .field-full {
        grid-column: 1 / -1;
    }

    .field label {
        display: block;
        margin-bottom: 6px;
        font-weight: 600;
        color: #333;
        font-size: 13px;
    }

    .field .value {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 13px;
        background-color: #f8f9fa;
        color: #333;
        min-height: 36px;
        box-sizing: border-box;
    }

    /* Summary card */
    .summary-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 20px;
        color: #fff;
        margin-bottom: 24px;
    }

    .summary-card h4 {
        font-size: 14px;
        font-weight: 600;
        margin: 0 0 12px 0;
        opacity: 0.9;
    }

    .summary-row {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
    }

    .summary-item {
        text-align: center;
    }

    .summary-value {
        font-size: 28px;
        font-weight: 700;
    }

    .summary-label {
        font-size: 12px;
        opacity: 0.85;
    }

    .score-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-top: 8px;
    }

    .score-table thead th {
        background: #f3f4f6;
        font-weight: 700;
        padding: 10px 12px;
        text-align: left;
        border-bottom: 1px solid #e5e7eb;
        color: #444;
        white-space: nowrap;
    }

    .score-table tbody td {
        padding: 10px 12px;
        border-bottom: 1px solid #e5e7eb;
        vertical-align: middle;
        color: #333;
    }

    .score-table tbody tr:hover {
        background: #f9f9f9;
    }

    .score-summary {
        display: flex;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap;
        margin-top: 14px;
        padding: 14px 18px;
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        font-size: 13px;
    }

    .score-summary strong {
        color: #1e3a5f;
    }

    .badge {
        padding: 4px 12px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        display: inline-block;
    }

    .badge-pass { background: #28a745; }
    .badge-fail { background: #dc3545; }
    .badge-none { background: #6b7280; }
    .badge-pending { background: #f59e0b; }

    .member-list {
        list-style: none;
        padding: 0;
        margin: 8px 0 0 0;
        font-size: 13px;
    }

    .member-list li {
        padding: 6px 0;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        gap: 8px;
    }

    .member-list li:last-child {
        border-bottom: none;
    }

    .member-role {
        color: var(--primary);
        font-weight: 600;
        min-width: 90px;
    }

    .role-chair { color: #dc2626; }
    .role-secretary { color: #2563eb; }
    .role-reviewer { color: #7c3aed; }
    .role-member { color: #059669; }

    .hd-info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 14px;
    }

    .hd-info-item label {
        display: block;
        font-weight: 600;
        color: #444;
        font-size: 12px;
        margin-bottom: 4px;
    }

    .hd-info-item .val {
        font-size: 13px;
        color: #333;
    }

    .tab-group {
        display: flex;
        gap: 0;
        margin-bottom: 0;
    }

    .tab-btn {
        padding: 10px 24px;
        border: 1px solid #ddd;
        border-bottom: none;
        background: #f3f4f6;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border-radius: 6px 6px 0 0;
        color: #666;
        transition: 0.15s;
    }

    .tab-btn.active {
        background: #fff;
        color: var(--primary);
        border-color: var(--primary);
        border-bottom: 2px solid #fff;
        margin-bottom: -1px;
        z-index: 1;
    }

    .tab-content {
        border: 1px solid #ddd;
        border-radius: 0 8px 8px 8px;
        padding: 20px;
        background: #fff;
        display: none;
    }

    .tab-content.active {
        display: block;
    }

    @@media (max-width: 768px) {
        .grid { grid-template-columns: 1fr; }
        .hd-info-grid { grid-template-columns: 1fr; }
        .dot-info { flex-direction: column; gap: 10px; align-items: flex-start; }
    }
</style>

<div class="content-body">
    <div class="content-card">
        <h2 class="page-title">Kết quả báo cáo hội đồng</h2>

        @if (!Model.CoDot)
        {
            <div class="alert-box alert-warning">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>@(Model.ThongBaoDot ?? "Không tìm thấy đợt đồ án đang mở.")</span>
            </div>
        }
        else
        {
            <!-- Thông tin đợt -->
            <div class="dot-info">
                <div>
                    <i class="fa-solid fa-calendar-days"></i>
                    <strong>Đợt:</strong> @(Model.TenDot ?? "---")
                </div>
                @if (!string.IsNullOrEmpty(Model.HocKi))
                {
                    <div>
                        <i class="fa-solid fa-graduation-cap"></i>
                        <strong>Học kỳ:</strong> @Model.HocKi
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.ThoiGianDot))
                {
                    <div>
                        <i class="fa-regular fa-clock"></i>
                        <span>@Model.ThoiGianDot</span>
                    </div>
                }
            </div>

            <!-- Thông tin sinh viên & đề tài -->
            <div class="section">
                <div class="grid">
                    <div class="field">
                        <label>MSSV</label>
                        <div class="value">@(Model.MaSinhVien ?? "---")</div>
                    </div>
                    <div class="field">
                        <label>Họ tên</label>
                        <div class="value">@(Model.HoTen ?? "---")</div>
                    </div>
                    <div class="field">
                        <label>Mã đề tài</label>
                        <div class="value">@(Model.MaDeTai ?? "---")</div>
                    </div>
                    <div class="field">
                        <label>GVHD</label>
                        <div class="value">@(Model.TenGVHD ?? "---")</div>
                    </div>
                    <div class="field field-full">
                        <label>Tên đề tài</label>
                        <div class="value">@(Model.TenDeTai ?? "---")</div>
                    </div>
                </div>
            </div>

            @if (!Model.CoDeTai)
            {
                <div class="alert-box alert-info">
                    <i class="fa-solid fa-circle-info"></i>
                    <span>@(Model.ThongBaoDot ?? "Bạn chưa được duyệt đề tài trong đợt hiện tại.")</span>
                </div>
            }
            else
            {
                <!-- Tổng hợp điểm (nếu có) -->
                @if (Model.DiemTrungBinhChung.HasValue || Model.CoDiemGVHD || Model.KetQuaBaoVe?.DiemTongKet != null)
                {
                    <div class="summary-card">
                        <h4><i class="fa-solid fa-chart-line"></i> Tổng hợp kết quả</h4>
                        <div class="summary-row">
                            @if (Model.DiemTrungBinhChung.HasValue)
                            {
                                <div class="summary-item">
                                    <div class="summary-value">@Model.DiemTrungBinhChung?.ToString("F2")</div>
                                    <div class="summary-label">Điểm trung bình</div>
                                </div>
                                <div class="summary-item">
                                    <div class="summary-value">@(Model.XepLoaiTotNghiep ?? "---")</div>
                                    <div class="summary-label">Xếp loại</div>
                                </div>
                            }
                            @if (Model.CoDiemGVHD)
                            {
                                <div class="summary-item">
                                    <div class="summary-value">@Model.DiemGVHD?.ToString("F1")</div>
                                    <div class="summary-label">GVHD (30%)</div>
                                </div>
                            }
                            @if (Model.KetQuaBaoVe?.DiemTongKet != null)
                            {
                                <div class="summary-item">
                                    <div class="summary-value">@Model.KetQuaBaoVe.DiemTongKet?.ToString("F1")</div>
                                    <div class="summary-label">Hội đồng (70%)</div>
                                </div>
                            }
                        </div>
                        <div style="margin-top: 10px; font-size: 11px; opacity: 0.8;">
                            <i class="fa-solid fa-info-circle"></i> 
                            Công thức: Điểm GVHD × 30% + Điểm Hội đồng bảo vệ × 70%
                        </div>
                    </div>
                }

                <div class="tab-group">
                    <button type="button" class="tab-btn active" onclick="switchTab('gvhd', this)">
                        <i class="fa-solid fa-user-tie"></i> Điểm GVHD (30%)
                    </button>
                    <button type="button" class="tab-btn" onclick="switchTab('hoidong', this)">
                        <i class="fa-solid fa-users"></i> Hội đồng bảo vệ (70%)
                    </button>
                </div>

                <div id="tab-gvhd" class="tab-content active">
                    @if (Model.KetQuaGiuaKy != null)
                    {
                        await Html.RenderPartialAsync("_KetQuaHoiDongSection", Model.KetQuaGiuaKy);
                    }
                    else
                    {
                        <div class="alert-box alert-info">
                            <i class="fa-solid fa-clock"></i>
                            <span>Chưa có kết quả đánh giá từ GVHD.</span>
                        </div>
                    }
                </div>
                <div id="tab-hoidong" class="tab-content">
                    @if (Model.KetQuaBaoVe != null)
                    {
                        await Html.RenderPartialAsync("_KetQuaHoiDongSection", Model.KetQuaBaoVe);
                    }
                    else
                    {
                        <div class="alert-box alert-info">
                            <i class="fa-solid fa-clock"></i>
                            <span>Chưa có kết quả từ Hội đồng bảo vệ.</span>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

<script>
    function switchTab(tabId, btn) {
        document.querySelectorAll('.tab-content').forEach(function (el) { el.classList.remove('active'); });
        document.querySelectorAll('.tab-btn').forEach(function (el) { el.classList.remove('active'); });
        document.getElementById('tab-' + tabId).classList.add('active');
        btn.classList.add('active');
    }
</script>
