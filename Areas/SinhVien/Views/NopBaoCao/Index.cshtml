@model NopBaoCaoIndexViewModel
@{
    ViewData["Title"] = "Nộp báo cáo";
}

<style>
    .content-card {
        background-color: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05);
    }

    .page-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        margin: 0 0 20px 0;
        text-transform: uppercase;
    }

    .dot-info {
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-size: 13px;
        color: #333;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dot-info i {
        color: #2563eb;
        font-size: 16px;
    }

    .dot-info strong {
        color: #1e3a5f;
    }

    .box-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .box-card {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        transition: all 0.2s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        background: #fff;
        position: relative;
    }

    .box-card:hover {
        border-color: #484BE0;
        box-shadow: 0 4px 16px rgba(72, 75, 224, 0.12);
        transform: translateY(-2px);
    }

    .box-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #fff;
        flex-shrink: 0;
    }

    .box-icon-decuong { background: #6366f1; }
    .box-icon-giuaky { background: #f59e0b; }
    .box-icon-cuoiky { background: #10b981; }

    .box-title {
        font-size: 15px;
        font-weight: 700;
        color: #1f2937;
        line-height: 1.3;
    }

    .box-time {
        font-size: 12px;
        color: #6b7280;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .box-time i {
        font-size: 13px;
        color: #9ca3af;
    }

    /* Trạng thái nộp */
    .status-badge {
        padding: 5px 12px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        color: #fff;
        display: inline-block;
        align-self: flex-start;
    }

    .status-approved { background: #16a34a; }
    .status-pending { background: #f59e0b; }
    .status-rejected { background: #dc2626; }
    .status-default { background: #6b7280; }

    /* Trạng thái giai đoạn - Tag ở góc trên */
    .phase-tag {
        position: absolute;
        top: 10px;
        right: 12px;
        font-size: 11px;
        font-weight: 600;
        border-radius: 4px;
        padding: 3px 10px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .phase-pending {
        color: #6b7280;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
    }

    .phase-open {
        color: #16a34a;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
    }

    .phase-closed {
        color: #dc2626;
        background: #fef2f2;
        border: 1px solid #fecaca;
    }

    .phase-unconfigured {
        color: #9ca3af;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
    }

    .alert-info-box {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 24px;
        color: #1e40af;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-warning-box {
        background: #fffbeb;
        border: 1px solid #fde68a;
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 24px;
        color: #92400e;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    @@media (max-width: 768px) {
        .box-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="content-body">
    <div class="content-card">
        <h2 class="page-title">Nộp báo cáo</h2>

        @if (Model.CoDot)
        {
            <div class="dot-info">
                <i class="fa-solid fa-calendar-days"></i>
                <span>@Model.ThongBaoDot</span>
            </div>

            <div class="box-grid">
                @{ await Html.RenderPartialAsync("_BoxCard", Model.DeCuong, new ViewDataDictionary(ViewData) { { "IconClass", "box-icon-decuong" }, { "Icon", "fa-solid fa-file-lines" } }); }
                @{ await Html.RenderPartialAsync("_BoxCard", Model.GiuaKy, new ViewDataDictionary(ViewData) { { "IconClass", "box-icon-giuaky" }, { "Icon", "fa-solid fa-file-circle-check" } }); }
                @{ await Html.RenderPartialAsync("_BoxCard", Model.CuoiKy, new ViewDataDictionary(ViewData) { { "IconClass", "box-icon-cuoiky" }, { "Icon", "fa-solid fa-file-shield" } }); }
            </div>
        }
        else
        {
            <div class="alert-warning-box">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>@(Model.ThongBaoDot ?? "Không tìm thấy đợt đồ án hiện tại.")</span>
            </div>
        }
    </div>
</div>
