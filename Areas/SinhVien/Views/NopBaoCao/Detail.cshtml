@model NopBaoCaoDetailViewModel
@{
    ViewData["Title"] = Model.TieuDe;

    var canUpload = Model.DangMo && Model.TrangThai != "DA_DUYET";
    var hasFile = !string.IsNullOrEmpty(Model.FilePath);
}

<style>
    .content-card {
        background-color: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05);
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 1px solid #eee;
    }

    .btn-back-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background-color: #f3f4f6;
        color: #555;
        border-radius: 50%;
        text-decoration: none;
        transition: 0.2s;
        font-size: 14px;
    }

    .btn-back-circle:hover {
        background-color: #e5e7eb;
        color: #2563eb;
        transform: translateX(-2px);
    }

    .form-title {
        font-size: 18px;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
    }

    .meta-card {
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        padding: 14px 18px;
        margin-bottom: 24px;
        display: flex;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap;
        font-size: 13px;
        color: #333;
    }

    .meta-card strong {
        color: #1e3a5f;
    }

    .status-badge {
        padding: 5px 12px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        color: #fff;
        display: inline-block;
    }

    .status-approved { background: #16a34a; }
    .status-pending { background: #f59e0b; }
    .status-rejected { background: #dc2626; }
    .status-default { background: #6b7280; }

    .section {
        margin-bottom: 22px;
    }

    .section-title {
        font-size: 14px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
    }

    .field {
        display: flex;
        flex-direction: column;
        margin-bottom: 14px;
    }

    .field label {
        display: block;
        margin-bottom: 6px;
        font-weight: 600;
        color: #333;
        font-size: 13px;
    }

    .field .value {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        background-color: #f9fafb;
        color: #333;
        font-size: 13px;
        min-height: 38px;
        box-sizing: border-box;
    }

    .field textarea {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 13px;
        resize: vertical;
        min-height: 80px;
        box-sizing: border-box;
    }

    .field textarea:focus {
        outline: none;
        border-color: #484BE0;
        box-shadow: 0 0 0 2px rgba(72, 75, 224, 0.1);
    }

    .upload-zone {
        border: 2px dashed #d1d5db;
        border-radius: 8px;
        padding: 30px 20px;
        text-align: center;
        color: #6b7280;
        font-size: 13px;
        cursor: pointer;
        transition: 0.2s;
        position: relative;
    }

    .upload-zone:hover {
        border-color: #484BE0;
        background: #f8f9ff;
    }

    .upload-zone input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    .upload-zone i {
        font-size: 28px;
        color: #9ca3af;
        display: block;
        margin-bottom: 10px;
    }

    .upload-zone .hint {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 6px;
    }

    .file-current {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 12px;
    }

    .file-current i {
        color: #16a34a;
        font-size: 16px;
    }

    .file-current a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 600;
    }

    .file-current a:hover {
        text-decoration: underline;
    }

    .nhan-xet-box {
        padding: 14px 16px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 8px;
        font-size: 13px;
        color: #78350f;
        white-space: pre-wrap;
        line-height: 1.6;
    }

    .btn {
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
    }

    .btn-primary {
        background: #484BE0;
        color: #fff;
    }

    .btn-primary:hover:not(:disabled) {
        background: #3538b2;
    }

    .btn-primary:disabled {
        background: #9ca3af;
        cursor: not-allowed;
    }

    .actions {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

    .alert-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
        padding: 10px 14px;
        border-radius: 6px;
        font-size: 13px;
        margin-bottom: 16px;
    }

    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        padding: 10px 14px;
        border-radius: 6px;
        font-size: 13px;
        margin-bottom: 16px;
    }

    .time-tag {
        font-size: 12px;
        color: #6b7280;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    @@media (max-width: 768px) {
        .grid-2 { grid-template-columns: 1fr; }
        .meta-card { flex-direction: column; gap: 8px; }
    }
</style>

<div class="content-body">
    <div class="content-card">
        <div class="form-header">
            <a asp-action="Index" class="btn-back-circle" title="Quay lại">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h3 class="form-title">@Model.TieuDe</h3>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">
                <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-error">
                <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Error"]
            </div>
        }

        <div class="meta-card">
            <div><strong>Đợt:</strong> @(Model.TenDot ?? "---")</div>
            <div>
                <strong>Trạng thái gửi:</strong>
                @if (hasFile)
                {
                    <span style="color:#16a34a; font-weight:600;">Đã nộp</span>
                }
                else
                {
                    <span style="color:#6b7280; font-weight:600;">Chưa nộp</span>
                }
            </div>
            <div>
                <strong>Trạng thái duyệt:</strong>
                <span class="status-badge @Model.TrangThaiCss">@Model.TrangThaiText</span>
            </div>
            <div class="time-tag">
                <i class="fa-regular fa-clock"></i>
                @if (Model.ThoiGianBatDau != null && Model.ThoiGianKetThuc != null)
                {
                    <span>@Model.ThoiGianBatDau — @Model.ThoiGianKetThuc</span>
                }
                else
                {
                    <span>Chưa cấu hình</span>
                }
                @if (Model.DangMo)
                {
                    <span style="color:#16a34a; font-weight:600; font-size:11px; border:1px solid #bbf7d0; background:#f0fdf4; padding:2px 8px; border-radius:4px; margin-left:4px;">Đang mở</span>
                }
            </div>
        </div>

        @if (hasFile)
        {
            <div class="file-current">
                <i class="fa-solid fa-file-pdf"></i>
                <a href="@Model.FilePath" target="_blank">@Model.TenFile</a>
                @if (!string.IsNullOrEmpty(Model.NgaySuaDoiCuoi))
                {
                    <span style="color:#6b7280; font-size:12px; margin-left:auto;">Sửa đổi lần cuối: @Model.NgaySuaDoiCuoi</span>
                }
            </div>
        }

        <form asp-action="NopFile" method="post" enctype="multipart/form-data">
            <input type="hidden" name="loai" value="@Model.LoaiBaoCao" />

            @if (canUpload)
            {
                <div class="section">
                    <div class="section-title">
                        @(hasFile ? "Nộp lại file" : "Nộp file")
                    </div>
                    <div class="upload-zone" id="dropZone">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <div>Kéo thả file hoặc <strong>nhấn để chọn</strong></div>
                        <div class="hint">.pdf, .doc, .docx, .zip — Tối đa 50MB</div>
                        <div id="selectedFileName" style="margin-top:8px; font-weight:600; color:#484BE0;"></div>
                        <input type="file" name="file" id="fileInput"
                               accept=".pdf,.doc,.docx,.zip" />
                    </div>
                </div>

                <div class="field">
                    <label>Ghi chú gửi kèm</label>
                    <textarea name="ghiChu" placeholder="Nhập ghi chú cho GVHD (nếu có)...">@Model.GhiChuGui</textarea>
                </div>
            }
            else if (Model.TrangThai == "DA_DUYET")
            {
                @if (!string.IsNullOrEmpty(Model.GhiChuGui))
                {
                    <div class="field">
                        <label>Ghi chú đã gửi</label>
                        <div class="value">@Model.GhiChuGui</div>
                    </div>
                }
            }
            else if (!Model.DangMo)
            {
                @if (!string.IsNullOrEmpty(Model.GhiChuGui))
                {
                    <div class="field">
                        <label>Ghi chú đã gửi</label>
                        <div class="value">@Model.GhiChuGui</div>
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(Model.NhanXetGVHD))
            {
                <div class="section">
                    <div class="section-title">Nhận xét GVHD</div>
                    <div class="nhan-xet-box">@Model.NhanXetGVHD</div>
                </div>
            }

            @if (canUpload)
            {
                <div class="actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-paper-plane"></i> @(hasFile ? "Nộp lại báo cáo" : "Nộp báo cáo")
                    </button>
                </div>
            }
        </form>
    </div>
</div>

<script>
    var fileInput = document.getElementById('fileInput');
    var selectedFileName = document.getElementById('selectedFileName');
    if (fileInput) {
        fileInput.addEventListener('change', function () {
            if (fileInput.files.length > 0) {
                selectedFileName.textContent = fileInput.files[0].name;
            } else {
                selectedFileName.textContent = '';
            }
        });
    }
</script>
