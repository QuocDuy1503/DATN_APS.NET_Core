@model NopBaoCaoBoxItem

<a asp-action="Detail" asp-route-loai="@Model.LoaiBaoCao" class="box-card">
    @* Trạng thái giai đoạn: Chưa mở / Đang mở / Đã đóng *@
    <span class="phase-tag @Model.TrangThaiGiaiDoanCss">
        @if (Model.TrangThaiGiaiDoan == "DANG_MO")
        {
            <i class="fa-solid fa-unlock"></i>
        }
        else if (Model.TrangThaiGiaiDoan == "DA_DONG")
        {
            <i class="fa-solid fa-lock"></i>
        }
        else if (Model.TrangThaiGiaiDoan == "CHUA_MO")
        {
            <i class="fa-regular fa-clock"></i>
        }
        else
        {
            <i class="fa-solid fa-circle-question"></i>
        }
        @Model.TrangThaiGiaiDoanText
    </span>

    <div class="box-icon @ViewData["IconClass"]">
        <i class="@ViewData["Icon"]"></i>
    </div>

    <div class="box-title">@Model.TieuDe</div>

    <div class="box-time">
        <i class="fa-regular fa-clock"></i>
        @if (!string.IsNullOrEmpty(Model.ThoiGianBatDau) && !string.IsNullOrEmpty(Model.ThoiGianKetThuc))
        {
            <span>@Model.ThoiGianBatDau — @Model.ThoiGianKetThuc</span>
        }
        else
        {
            <span style="color: #9ca3af; font-style: italic;">Chưa cấu hình thời gian</span>
        }
    </div>

    <span class="status-badge @Model.TrangThaiCss">@Model.TrangThaiText</span>
</a>
